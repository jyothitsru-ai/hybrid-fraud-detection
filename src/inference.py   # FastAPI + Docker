class TransactionFeatures(BaseModel):
    """Input schema for a single transaction.

    All PCA-anonymised features V1–V28 are required along with the
    original Amount field and all engineered features produced by
    preprocessing.py.  The transaction_id is caller-supplied and
    propagated through the audit log.

    Paper: "raw transaction attributes, device and channel identifiers,
    merchant metadata, and account history pointers."
    """

    transaction_id           : str   = Field(default_factory=lambda: str(uuid.uuid4()),
                                             description="Unique transaction identifier.")
    # PCA features (anonymised, float)
    V1  : float; V2  : float; V3  : float; V4  : float; V5  : float
    V6  : float; V7  : float; V8  : float; V9  : float; V10 : float
    V11 : float; V12 : float; V13 : float; V14 : float; V15 : float
    V16 : float; V17 : float; V18 : float; V19 : float; V20 : float
    V21 : float; V22 : float; V23 : float; V24 : float; V25 : float
    V26 : float; V27 : float; V28 : float
    # Raw numeric
    Amount                   : float = Field(..., ge=0.0,  description="Transaction amount (USD).")
    # Engineered features (computed upstream by feature store / preprocessing.py)
    log_amount               : float = Field(..., description="log(1 + Amount)")
    amount_zscore_rolling    : float = Field(..., description="Amount z-score (expanding window).")
    time_delta               : float = Field(..., ge=0.0,  description="Seconds since previous transaction.")
    tx_velocity_100          : float = Field(..., ge=0.0,  description="Transactions in last 100-row window.")
    tx_velocity_500          : float = Field(..., ge=0.0,  description="Transactions in last 500-row window.")
    hour_of_day              : int   = Field(..., ge=0, le=23, description="Hour of day (0–23).")
    is_night                 : int   = Field(..., ge=0, le=1,  description="1 if hour in [0,5].")
    amount_rolling_mean_100  : float = Field(..., description="Rolling mean of Amount (100-row window).")
    amount_rolling_std_100   : float = Field(..., ge=0.0,  description="Rolling std of Amount (100-row window).")

    model_config = {"extra": "allow"}   # accept extra fields gracefully

    @field_validator("Amount")
    @classmethod
    def amount_must_be_finite(cls, v: float) -> float:
        if not np.isfinite(v):
            raise ValueError("Amount must be a finite number.")
        return v



class _ModelRegistry:
    """Singleton container for all loaded model artefacts.

    Loaded once at application startup in the lifespan handler and reused
    for every request.  All fields are Optional so startup errors surface
    clearly rather than silently failing at request time.
    """
    dnn_encoder   : Optional[FraudDNNEncoder]      = None
    ensemble_head : Optional[EnsembleHead]          = None
    calibrator    : Optional[IsotonicCalibrator]    = None
    shap_explainer: Optional[FraudSHAPExplainer]    = None
    scaler        : Optional[Any]                   = None
    feature_cols  : List[str]                       = ALL_FEATURE_COLS
    embedding_dim : int                             = EMBEDDING_DIM
    tau_star      : float                           = TAU_STAR
    model_version : str                             = MODEL_VERSION


_registry = _ModelRegistry()

# ── In-memory stores ──────────────────────────────────────────────────────────

# Latency samples (rolling window) — used by GET /metrics
_predict_latencies_ms: deque = deque(maxlen=LATENCY_WINDOW)
_explain_latencies_ms: deque = deque(maxlen=LATENCY_WINDOW)

# Request counters
_counters: Dict[str, int] = {
    "total_requests"  : 0,
    "fraud_flags"     : 0,
    "legit_decisions" : 0,
    "errors"          : 0,
}

# Async SHAP explanation cache: request_id -> explanation dict
# Bounded deque prevents unbounded memory growth in long-running containers.
_explanation_cache: Dict[str, Dict] = {}
_explanation_order: deque           = deque(maxlen=EXPLANATION_CACHE_SIZE)


# ═══════════════════════════════════════════════════════════════════════════════
# Startup / shutdown lifespan
# ═══════════════════════════════════════════════════════════════════════════════

@asynccontextmanager
async def lifespan(app: FastAPI):
    """Load all model artefacts once at server startup.

    FastAPI lifespan events ensure models are loaded before the first
    request is served and resources are released cleanly on shutdown.
    """
    logger.info("Loading model artefacts …")
    t0 = time.perf_counter()

    try:
        # DNN encoder
        _registry.dnn_encoder = FraudDNNEncoder.load(MODEL_DNN_PATH, device=DEVICE)
        _registry.dnn_encoder.eval()
        logger.info("  DNN encoder loaded from %s", MODEL_DNN_PATH)

        # Ensemble head (includes its own calibrator fitted during training)
        _registry.ensemble_head = EnsembleHead.load(MODEL_ENSEMBLE_PATH)
        logger.info("  Ensemble head loaded from %s", MODEL_ENSEMBLE_PATH)

        # Standalone isotonic calibrator (may override the one inside EnsembleHead)
        if Path(MODEL_CALIBRATOR_PATH).exists():
            _registry.calibrator = IsotonicCalibrator.load(MODEL_CALIBRATOR_PATH)
            logger.info("  Calibrator loaded from %s", MODEL_CALIBRATOR_PATH)

        # SHAP explainer (optional — if not present, /explain returns 503)
        if Path(MODEL_SHAP_PATH).exists():
            _registry.shap_explainer = FraudSHAPExplainer.load(
                MODEL_SHAP_PATH, _registry.ensemble_head
            )
            logger.info("  SHAP explainer loaded from %s", MODEL_SHAP_PATH)
        else:
            logger.warning(
                "SHAP explainer not found at %s. /explain endpoints will return 503.",
                MODEL_SHAP_PATH,
            )

        # Feature scaler
        _registry.scaler = joblib.load(SCALER_PATH)
        logger.info("  Scaler loaded from %s", SCALER_PATH)

        # Feature column list (may be overridden by saved pkl)
        feature_cols_path = Path("data/processed/feature_cols.pkl")
        if feature_cols_path.exists():
            _registry.feature_cols = joblib.load(feature_cols_path)

        elapsed = (time.perf_counter() - t0) * 1000
        logger.info(
            "All artefacts loaded in %.1f ms.  "
            "Features=%d  EmbeddingDim=%d  τ*=%.4f  Version=%s",
            elapsed,
            len(_registry.feature_cols),
            _registry.embedding_dim,
            _registry.tau_star,
            _registry.model_version,
        )

    except Exception as exc:
        logger.error("Failed to load model artefacts: %s", exc, exc_info=True)
        raise

    yield  # Server runs here

    logger.info("Shutting down inference server.")



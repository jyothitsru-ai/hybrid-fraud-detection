_SERVER_START = time.time()


def _transaction_to_vector(tx: TransactionFeatures) -> np.ndarray:
    """Convert a TransactionFeatures Pydantic model to a raw feature vector.

    Extracts features in the exact order defined by _registry.feature_cols
    so the scaler and DNN receive the correct input dimensionality.

    Parameters
    ----------
    tx : TransactionFeatures

    Returns
    -------
    np.ndarray, shape (1, n_features), dtype float32
        Unscaled feature vector.
    """
    tx_dict = tx.model_dump()
    missing = [c for c in _registry.feature_cols if c not in tx_dict]
    if missing:
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,
            detail=f"Missing required feature(s): {missing}",
        )
    vec = np.array(
        [float(tx_dict[c]) for c in _registry.feature_cols],
        dtype=np.float32,
    ).reshape(1, -1)
    return vec


def _score_vectors(
    raw_vectors: np.ndarray,
) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
    """Run the full synchronous scoring pipeline on a batch of raw vectors.

    Pipeline:
        raw features → StandardScaler → DNN encode → XGBoost score
        → isotonic calibrate → threshold

    Paper: "p50 and p99 latency is single-digit milliseconds"

    Parameters
    ----------
    raw_vectors : np.ndarray, shape (N, n_features)
        Unscaled feature vectors.

    Returns
    -------
    fraud_scores : np.ndarray, shape (N,)
        Calibrated fraud probabilities.
    decisions : np.ndarray, shape (N,), int
        Binary decisions (0 or 1) at τ*.
    embeddings : np.ndarray, shape (N, embedding_dim)
        DNN latent embeddings z (used by async SHAP background task).
    """
    # Step 1 — normalise
    scaled = _registry.scaler.transform(raw_vectors).astype(np.float32)

    # Step 2 — DNN encode (no gradient needed at inference)
    with torch.no_grad():
        z_tensor = torch.from_numpy(scaled).to(DEVICE)
        embeddings = _registry.dnn_encoder.encode(z_tensor).cpu().numpy()

    # Step 3 — ensemble score + calibrate
    fraud_scores = _registry.ensemble_head.predict_proba(embeddings)

    # Step 4 — threshold decision
    decisions = (fraud_scores >= _registry.tau_star).astype(int)

    return fraud_scores, decisions, embeddings


def _quick_reason_codes(
    embeddings: np.ndarray,
    top_n: int = 3,
) -> List[str]:
    """Generate lightweight reason codes without full TreeSHAP.

    Uses the ensemble head's feature importances (not SHAP) to produce
    instant reason codes on the synchronous path.  Full SHAP explanations
    are computed asynchronously and retrieved via GET /explain/{id}.

    Parameters
    ----------
    embeddings : np.ndarray, shape (1, embedding_dim)
    top_n : int, default 3

    Returns
    -------
    List[str]
        Plain-English reason strings for the analyst dashboard.
    """
    try:
        clf        = _registry.ensemble_head.clf_
        importances = np.array(clf.feature_importances_)
        top_idx     = np.argsort(importances)[-top_n:][::-1]
        feat_names  = [f"z_{i:02d}" for i in range(len(importances))]
        codes = [
            f"{feat_names[i]} (importance={importances[i]:.3f})"
            for i in top_idx
        ]
        return codes
    except Exception:
        return []


# ═══════════════════════════════════════════════════════════════════════════════
# Async SHAP background task
# ═══════════════════════════════════════════════════════════════════════════════

async def _run_shap_async(
    request_id: str,
    transaction_id: str,
    embeddings: np.ndarray,
    fraud_score: float,
    decision: int,
) -> None:
    """Compute full TreeSHAP explanation in a background task.

    Runs in the FastAPI BackgroundTasks pool so the synchronous /predict
    response is returned immediately while SHAP computes asynchronously.

    Paper: "The classifier is strictly synchronous and explanations are
    asynchronous on the serving path, so that p50 and p99 latency is
    single-digit milliseconds and the SHAP artifact can reach analyst
    consoles a few hundred milliseconds later."

    Result is stored in _explanation_cache keyed by request_id.

    Parameters
    ----------
    request_id     : str
    transaction_id : str
    embeddings     : np.ndarray, shape (1, embedding_dim)
    fraud_score    : float
    decision       : int
    """
    if _registry.shap_explainer is None:
        return

    t0 = time.perf_counter()
    try:
        artifact = _registry.shap_explainer.explanation_artifact(
            z              = embeddings[0],
            fraud_score    = fraud_score,
            decision       = decision,
            transaction_id = transaction_id,
            tau_star       = _registry.tau_star,
            model_version  = _registry.model_version,
        )
        artifact["request_id"] = request_id
        artifact["latency_ms"] = round((time.perf_counter() - t0) * 1000, 3)
        artifact["model_version"] = _registry.model_version

        # Evict oldest entry if cache is full
        if len(_explanation_cache) >= EXPLANATION_CACHE_SIZE:
            oldest = _explanation_order.popleft()
            _explanation_cache.pop(oldest, None)

        _explanation_cache[request_id] = artifact
        _explanation_order.append(request_id)

        _explain_latencies_ms.append(artifact["latency_ms"])
        logger.debug(
            "SHAP complete: request_id=%s  latency=%.1f ms",
            request_id, artifact["latency_ms"],
        )
    except Exception as exc:
        logger.error("SHAP background task failed for %s: %s", request_id, exc)


# ═══════════════════════════════════════════════════════════════════════════════
# API endpoints
# ═══════════════════════════════════════════════════════════════════════════════

@app.post(
    "/predict",
    response_model=FraudPrediction,
    summary="Score a single transaction",
    description=(
        "Synchronous fraud scoring endpoint.  Returns the fraud probability, "
        "binary decision at τ*, and top-3 reason codes in single-digit "
        "milliseconds.  Full SHAP explanation is computed asynchronously and "
        "retrievable via GET /explain/{request_id}."
    ),
)
async def predict(
    tx: TransactionFeatures,
    background_tasks: BackgroundTasks,
) -> FraudPrediction:
    """Score a single transaction synchronously.

    Implements the paper's two-path serving design:
    - Synchronous path: preprocess → DNN → ensemble → calibrate → decide
    - Async path (background): TreeSHAP → store in explanation cache
    """
    t0         = time.perf_counter()
    request_id = str(uuid.uuid4())

    try:
        # ── Synchronous scoring ───────────────────────────────────────────────
        raw_vec = _transaction_to_vector(tx)
        fraud_scores, decisions, embeddings = _score_vectors(raw_vec)

        fraud_score = float(fraud_scores[0])
        decision    = int(decisions[0])
        latency_ms  = (time.perf_counter() - t0) * 1000

        _predict_latencies_ms.append(latency_ms)
        _counters["total_requests"] += 1
        if decision == 1:
            _counters["fraud_flags"] += 1
        else:
            _counters["legit_decisions"] += 1

        # Quick reason codes (from feature importances, not SHAP)
        reason_codes = _quick_reason_codes(embeddings)

        logger.info(
            "PREDICT  tx=%-20s  score=%.4f  decision=%s  latency=%.2f ms",
            tx.transaction_id,
            fraud_score,
            "FRAUD" if decision else "LEGIT",
            latency_ms,
        )

        # ── Async SHAP background task ────────────────────────────────────────
        background_tasks.add_task(
            _run_shap_async,
            request_id     = request_id,
            transaction_id = tx.transaction_id,
            embeddings     = embeddings,
            fraud_score    = fraud_score,
            decision       = decision,
        )

        return FraudPrediction(
            transaction_id = tx.transaction_id,
            fraud_score    = round(fraud_score, 6),
            decision       = decision,
            decision_label = "FRAUD" if decision else "LEGITIMATE",
            threshold      = _registry.tau_star,
            model_version  = _registry.model_version,
            latency_ms     = round(latency_ms, 3),
            request_id     = request_id,
            reason_codes   = reason_codes,
        )

    except HTTPException:
        _counters["errors"] += 1
        raise
    except Exception as exc:
        _counters["errors"] += 1
        logger.error("Prediction error for tx=%s: %s", tx.transaction_id, exc, exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Scoring pipeline failed: {exc}",
        )


@app.post(
    "/predict/batch",
    response_model=BatchFraudPrediction,
    summary="Score a batch of transactions",
    description=(
        f"Score up to {MAX_BATCH_SIZE} transactions in one call.  "
        "Batching amortises DNN and ensemble overhead — preferred for "
        "bulk replay or back-testing scenarios."
    ),
)
async def predict_batch(
    batch: BatchTransactionRequest,
    background_tasks: BackgroundTasks,
) -> BatchFraudPrediction:
    """Score a batch of transactions.

    Stacks all feature vectors into a single numpy matrix and runs the
    DNN and ensemble in one vectorised forward pass.
    """
    t0 = time.perf_counter()

    try:
        # Stack raw vectors
        raw_vectors = np.vstack([
            _transaction_to_vector(tx) for tx in batch.transactions
        ])

        fraud_scores, decisions, embeddings = _score_vectors(raw_vectors)
        batch_latency_ms = (time.perf_counter() - t0) * 1000

        predictions = []
        for i, tx in enumerate(batch.transactions):
            request_id   = str(uuid.uuid4())
            fraud_score  = float(fraud_scores[i])
            decision     = int(decisions[i])
            reason_codes = _quick_reason_codes(embeddings[i : i + 1])

            _predict_latencies_ms.append(batch_latency_ms / len(batch.transactions))
            _counters["total_requests"] += 1
            if decision == 1:
                _counters["fraud_flags"] += 1
            else:
                _counters["legit_decisions"] += 1

            background_tasks.add_task(
                _run_shap_async,
                request_id     = request_id,
                transaction_id = tx.transaction_id,
                embeddings     = embeddings[i : i + 1],
                fraud_score    = fraud_score,
                decision       = decision,
            )

            predictions.append(FraudPrediction(
                transaction_id = tx.transaction_id,
                fraud_score    = round(fraud_score, 6),
                decision       = decision,
                decision_label = "FRAUD" if decision else "LEGITIMATE",
                threshold      = _registry.tau_star,
                model_version  = _registry.model_version,
                latency_ms     = round(batch_latency_ms / len(batch.transactions), 3),
                request_id     = request_id,
                reason_codes   = reason_codes,
            ))

        n_fraud = sum(p.decision for p in predictions)
        logger.info(
            "BATCH  n=%d  fraud=%d  batch_latency=%.2f ms  per_tx=%.2f ms",
            len(predictions), n_fraud, batch_latency_ms,
            batch_latency_ms / len(predictions),
        )

        return BatchFraudPrediction(
            predictions      = predictions,
            n_fraud_flagged  = n_fraud,
            batch_latency_ms = round(batch_latency_ms, 3),
        )

    except HTTPException:
        _counters["errors"] += 1
        raise
    except Exception as exc:
        _counters["errors"] += 1
        logger.error("Batch prediction error: %s", exc, exc_info=True)
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Batch scoring failed: {exc}",
        )


@app.get(
    "/explain/{request_id}",
    response_model=ExplanationResponse,
    summary="Retrieve async SHAP explanation",
    description=(
        "Retrieve the full TreeSHAP explanation for a previously scored "
        "transaction.  SHAP runs asynchronously after /predict returns; "
        "poll this endpoint until the explanation is available (typically "
        "within 500 ms)."
    ),
)
async def get_explanation(request_id: str) -> ExplanationResponse:
    """Return the stored SHAP explanation for a request_id.

    Paper: "each fraud alert is accompanied by an SHAP explanation,
    and interpretability is further supported through live operations."

    Returns 404 if the explanation has not been computed yet (poll again),
    503 if the SHAP explainer was not loaded at startup.
    """
    if _registry.shap_explainer is None:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="SHAP explainer not loaded.  Check MODEL_SHAP_PATH.",
        )

    artifact = _explanation_cache.get(request_id)
    if artifact is None:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=(
                f"Explanation for request_id='{request_id}' not yet available "
                "or has expired.  Retry in 200–500 ms."
            ),
        )

    return ExplanationResponse(
        request_id           = request_id,
        transaction_id       = artifact.get("transaction_id", ""),
        fraud_score          = artifact.get("fraud_score", 0.0),
        decision             = artifact.get("decision", 0),
        base_value           = artifact.get("shap_base_value", 0.0),
        shap_total           = artifact.get("shap_total", 0.0),
        shap_boundary        = artifact.get("shap_boundary", 0.0),
        shap_margin          = artifact.get("shap_margin", 0.0),
        shap_values          = {
            d["feature"]: d["shap"]
            for d in artifact.get("top_drivers", [])
        },
        top_positive_drivers = [
            d for d in artifact.get("top_drivers", []) if d.get("shap", 0) > 0
        ],
        top_negative_drivers = [
            d for d in artifact.get("top_drivers", []) if d.get("shap", 0) < 0
        ],
        reason_codes         = artifact.get("reason_codes", []),
        latency_ms           = artifact.get("latency_ms", 0.0),
        model_version        = artifact.get("model_version", _registry.model_version),
    )


@app.get(
    "/health",
    response_model=HealthResponse,
    summary="Liveness probe",
    description="Kubernetes/Docker liveness and readiness probe endpoint.",
)
async def health() -> HealthResponse:
    """Return server health status.

    Used by Docker HEALTHCHECK and Kubernetes liveness probes.
    Returns HTTP 200 when the model is loaded and ready to serve.
    Returns HTTP 503 when artefacts have not been loaded.
    """
    model_loaded = (
        _registry.dnn_encoder   is not None
        and _registry.ensemble_head is not None
        and _registry.scaler        is not None
    )
    shap_loaded = _registry.shap_explainer is not None
    uptime      = round(time.time() - _SERVER_START, 1)

    if not model_loaded:
        raise HTTPException(
            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
            detail="Model artefacts not loaded.",
        )

    return HealthResponse(
        status        = "ok",
        model_loaded  = model_loaded,
        shap_loaded   = shap_loaded,
        model_version = _registry.model_version,
        uptime_s      = uptime,
    )


@app.get(
    "/metrics",
    response_model=MetricsResponse,
    summary="Inference metrics",
    description=(
        "Latency percentiles and request counters.  "
        "Paper: 'p50 and p99 latency is single-digit milliseconds'."
    ),
)
async def metrics() -> MetricsResponse:
    """Return rolling latency statistics and request counters.

    The paper reports p50 and p99 predict latency on commodity CPUs.
    This endpoint makes those numbers observable for each deployed instance.
    """
    def percentile(data: deque, p: float) -> float:
        arr = np.array(data)
        return float(np.percentile(arr, p)) if len(arr) > 0 else 0.0

    total   = _counters["total_requests"]
    flagged = _counters["fraud_flags"]

    return MetricsResponse(
        total_requests   = total,
        fraud_flags      = flagged,
        legit_decisions  = _counters["legit_decisions"],
        errors           = _counters["errors"],
        fraud_rate_pct   = round(flagged / max(total, 1) * 100, 4),
        p50_latency_ms   = round(percentile(_predict_latencies_ms, 50),  3),
        p95_latency_ms   = round(percentile(_predict_latencies_ms, 95),  3),
        p99_latency_ms   = round(percentile(_predict_latencies_ms, 99),  3),
        explain_p50_ms   = round(percentile(_explain_latencies_ms, 50),  3),
        explain_p99_ms   = round(percentile(_explain_latencies_ms, 99),  3),
        pending_explains = max(0, _counters["total_requests"] - len(_explanation_cache)),
    )



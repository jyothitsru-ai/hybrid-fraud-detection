@dataclass
class TrainingHistory:
    """Container for per-epoch metrics recorded during :func:`train_one_fold`.

    Attributes
    ----------
    train_loss : List[float]
        Mean focal loss per epoch over all training batches.
    val_roc_auc : List[float]
        Validation ROC-AUC after each epoch.
    val_pr_auc : List[float]
        Validation PR-AUC after each epoch (primary metric for imbalanced data).
    best_epoch : int
        Epoch index (0-based) at which the best val_pr_auc was recorded.
    training_time_s : float
        Wall-clock seconds elapsed for the full training run.
    """

    train_loss     : List[float] = field(default_factory=list)
    val_roc_auc    : List[float] = field(default_factory=list)
    val_pr_auc     : List[float] = field(default_factory=list)
    best_epoch     : int         = 0
    training_time_s: float       = 0.0

    @property
    def best_val_pr_auc(self) -> float:
        """PR-AUC at the best epoch."""
        return self.val_pr_auc[self.best_epoch] if self.val_pr_auc else 0.0

    @property
    def best_val_roc_auc(self) -> float:
        """ROC-AUC at the best epoch."""
        return self.val_roc_auc[self.best_epoch] if self.val_roc_auc else 0.0

    def summary(self) -> str:
        """One-line summary string for logging."""
        return (
            f"Epochs={len(self.train_loss)}  "
            f"BestEpoch={self.best_epoch + 1}  "
            f"BestPR-AUC={self.best_val_pr_auc:.4f}  "
            f"BestROC-AUC={self.best_val_roc_auc:.4f}  "
            f"Time={self.training_time_s:.1f}s"
        )


# ═══════════════════════════════════════════════════════════════════════════════
# Training loop
# ═══════════════════════════════════════════════════════════════════════════════


def train_one_fold(
    X_train: np.ndarray,
    y_train: np.ndarray,
    X_val: np.ndarray,
    y_val: np.ndarray,
    input_dim: int,
    hidden_dims: List[int] = DEFAULT_HIDDEN_DIMS,
    embedding_dim: int = DEFAULT_EMBEDDING_DIM,
    dropout: float = DEFAULT_DROPOUT,
    focal_alpha: float = DEFAULT_FOCAL_ALPHA,
    focal_gamma: float = DEFAULT_FOCAL_GAMMA,
    lr: float = DEFAULT_LR,
    weight_decay: float = DEFAULT_WEIGHT_DECAY,
    batch_size: int = DEFAULT_BATCH_SIZE,
    epochs: int = DEFAULT_EPOCHS,
    patience: int = DEFAULT_PATIENCE,
    device: Optional[torch.device] = None,
    log_every: int = 10,
) -> Tuple[FraudDNNEncoder, TrainingHistory]:
    """Train the DNN encoder for a single cross-validation fold.

    Implements the training procedure described in the paper:
        "The DNN is trained on the processed transaction data with binary
        cross-entropy loss and class weights, which are able to overcome
        the imbalance.  The Adam optimizer is used to perform optimization
        and early stopping is used to avoid overfitting."

    The primary metric for early stopping and model selection is
    **PR-AUC** (not ROC-AUC), because PR-AUC is more informative under
    extreme class imbalance — a model can achieve high ROC-AUC while
    still missing most fraud cases (the paper explicitly notes this in
    the Results Discussion section).

    Parameters
    ----------
    X_train : np.ndarray, shape (N_train, input_dim)
        SMOTE-augmented, scaled training features (from FoldPreprocessor).
    y_train : np.ndarray, shape (N_train,)
        Binary training labels (0 = legitimate, 1 = fraud).
    X_val : np.ndarray, shape (N_val, input_dim)
        Scaled validation features (not resampled).
    y_val : np.ndarray, shape (N_val,)
        Binary validation labels.
    input_dim : int
        Number of input features.  Must match ``X_train.shape[1]``.
    hidden_dims : List[int]
        Hidden layer widths.
    embedding_dim : int
        Latent embedding dimension (z).
    dropout : float
        Dropout probability.
    focal_alpha : float
        Focal loss α (minority class weight).
    focal_gamma : float
        Focal loss γ (focusing parameter).
    lr : float
        Adam learning rate.
    weight_decay : float
        Adam L2 regularisation coefficient.
    batch_size : int
        Mini-batch size.
    epochs : int
        Maximum number of training epochs.
    patience : int
        Number of epochs with no improvement in val PR-AUC before
        training is stopped early.
    device : torch.device, optional
        Training device.  Defaults to CUDA if available, else CPU.
    log_every : int, default 10
        Log training progress every *log_every* epochs.

    Returns
    -------
    model : FraudDNNEncoder
        The best model (weights from the epoch with highest val PR-AUC),
        in eval mode, on CPU.
    history : TrainingHistory
        Per-epoch metrics and summary statistics.

    Examples
    --------
    >>> model, history = train_one_fold(
    ...     X_train, y_train, X_val, y_val, input_dim=37
    ... )
    >>> print(history.summary())
    Epochs=34  BestEpoch=27  BestPR-AUC=0.9123  BestROC-AUC=0.9941  Time=48.3s
    >>> Z_train = model.extract_embeddings(X_train)
    """
    if device is None:
        device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

    logger.info(
        "Training DNN encoder on device=%s  "
        "train=%d  val=%d  epochs=%d  patience=%d",
        device, len(X_train), len(X_val), epochs, patience,
    )

    # ── Model, loss, optimiser ────────────────────────────────────────────────
    model = FraudDNNEncoder(
        input_dim=input_dim,
        hidden_dims=hidden_dims,
        embedding_dim=embedding_dim,
        dropout=dropout,
    ).to(device)

    criterion = FocalLoss(alpha=focal_alpha, gamma=focal_gamma)
    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=weight_decay)

    # ReduceLROnPlateau — halve LR if val PR-AUC stalls for 3 epochs
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(
        optimizer, mode="max", factor=0.5, patience=3, verbose=False
    )

    # ── DataLoader ────────────────────────────────────────────────────────────
    X_tr_t = torch.from_numpy(X_train.astype(np.float32))
    y_tr_t = torch.from_numpy(y_train.astype(np.float32))
    X_vl_t = torch.from_numpy(X_val.astype(np.float32)).to(device)
    y_vl_np = y_val  # kept as numpy for sklearn metrics

    loader = DataLoader(
        TensorDataset(X_tr_t, y_tr_t),
        batch_size=batch_size,
        shuffle=True,
        num_workers=0,
        pin_memory=(device.type == "cuda"),
    )

    # ── Training loop ─────────────────────────────────────────────────────────
    history          = TrainingHistory()
    best_pr_auc      = -1.0
    patience_counter = 0
    best_state_dict: Dict = {}
    t0 = time.perf_counter()

    for epoch in range(epochs):
        # ── Train ─────────────────────────────────────────────────────────────
        model.train()
        epoch_loss = 0.0
        for X_batch, y_batch in loader:
            X_batch = X_batch.to(device)
            y_batch = y_batch.to(device)

            optimizer.zero_grad(set_to_none=True)
            logits = model(X_batch)
            loss   = criterion(logits, y_batch)
            loss.backward()

            # Gradient clipping — prevents exploding gradients with focal loss
            nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
            optimizer.step()
            epoch_loss += loss.item()

        avg_loss = epoch_loss / len(loader)

        # ── Validate ──────────────────────────────────────────────────────────
        model.eval()
        with torch.no_grad():
            val_probs = model.predict_proba(X_vl_t).cpu().numpy()

        val_roc_auc = roc_auc_score(y_vl_np, val_probs)
        val_pr_auc  = average_precision_score(y_vl_np, val_probs)

        history.train_loss.append(avg_loss)
        history.val_roc_auc.append(val_roc_auc)
        history.val_pr_auc.append(val_pr_auc)

        scheduler.step(val_pr_auc)

        # ── Early stopping on PR-AUC ──────────────────────────────────────────
        if val_pr_auc > best_pr_auc:
            best_pr_auc      = val_pr_auc
            history.best_epoch = epoch
            patience_counter  = 0
            # Deep-copy weights to CPU to avoid device issues later
            best_state_dict   = {
                k: v.cpu().clone() for k, v in model.state_dict().items()
            }
        else:
            patience_counter += 1

        if (epoch + 1) % log_every == 0 or patience_counter == patience:
            logger.info(
                "  Epoch %3d/%d  loss=%.4f  val_PR-AUC=%.4f  val_ROC-AUC=%.4f  "
                "patience=%d/%d",
                epoch + 1, epochs,
                avg_loss, val_pr_auc, val_roc_auc,
                patience_counter, patience,
            )

        if patience_counter >= patience:
            logger.info("Early stopping triggered at epoch %d.", epoch + 1)
            break

    # ── Restore best weights ──────────────────────────────────────────────────
    model.load_state_dict(best_state_dict)
    model.cpu()
    model.eval()

    history.training_time_s = time.perf_counter() - t0
    logger.info("Training complete.  %s", history.summary())

    return model, history


# ═══════════════════════════════════════════════════════════════════════════════
# Multi-fold training (full cross-validation)
# ═══════════════════════════════════════════════════════════════════════════════


def train_all_folds(
    fold_data: List[dict],
    input_dim: int,
    save_dir: Optional[str | Path] = None,
    **kwargs,
) -> Tuple[List[FraudDNNEncoder], List[TrainingHistory]]:
    """Train the DNN encoder across all cross-validation folds.

    Iterates over the output of ``preprocessing.run_pipeline()`` and calls
    :func:`train_one_fold` for each fold, optionally saving each trained
    model to *save_dir*.

    Parameters
    ----------
    fold_data : List[dict]
        List of dicts with keys ``X_train``, ``y_train``, ``X_val``,
        ``y_val``.  Typically the first return value of
        ``preprocessing.run_pipeline()``.
    input_dim : int
        Number of input features (must match ``X_train.shape[1]``).
    save_dir : str or Path, optional
        If provided, each trained model is saved as
        ``{save_dir}/dnn_fold{k}.pt``.
    **kwargs
        Additional keyword arguments forwarded to :func:`train_one_fold`
        (e.g. ``embedding_dim``, ``epochs``, ``patience``).

    Returns
    -------
    models : List[FraudDNNEncoder]
        One trained encoder per fold.
    histories : List[TrainingHistory]
        One history object per fold.

    Examples
    --------
    >>> from src.preprocessing import run_pipeline
    >>> fold_data, feature_cols = run_pipeline("data/creditcard.csv")
    >>> models, histories = train_all_folds(
    ...     fold_data, input_dim=len(feature_cols),
    ...     save_dir="results/models"
    ... )
    >>> for k, h in enumerate(histories):
    ...     print(f"Fold {k+1}: {h.summary()}")
    """
    models: List[FraudDNNEncoder]    = []
    histories: List[TrainingHistory] = []

    for fold_idx, fold in enumerate(fold_data):
        logger.info("═══ DNN Fold %d/%d ═══", fold_idx + 1, len(fold_data))

        model, history = train_one_fold(
            X_train   = fold["X_train"],
            y_train   = fold["y_train"],
            X_val     = fold["X_val"],
            y_val     = fold["y_val"],
            input_dim = input_dim,
            **kwargs,
        )
        models.append(model)
        histories.append(history)

        if save_dir is not None:
            save_path = Path(save_dir) / f"dnn_fold{fold_idx}.pt"
            model.save(save_path)

    # Print cross-fold summary
    pr_aucs = [h.best_val_pr_auc for h in histories]
    logger.info(
        "All folds complete.  PR-AUC per fold: %s  Mean=%.4f ± %.4f",
        [f"{v:.4f}" for v in pr_aucs],
        np.mean(pr_aucs),
        np.std(pr_aucs),
    )

    return models, histories



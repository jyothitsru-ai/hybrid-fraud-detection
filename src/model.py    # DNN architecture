# ── Default hyperparameters (match paper description) ─────────────────────────

#: Hidden layer widths.  Paper: "three to five fully connected hidden layers."
DEFAULT_HIDDEN_DIMS: List[int] = [256, 128, 64]

#: Dimension of the latent embedding z passed to the tree ensemble.
DEFAULT_EMBEDDING_DIM: int = 32

#: Dropout probability applied after each hidden layer.
DEFAULT_DROPOUT: float = 0.3

#: Focal loss α — class weight for the minority (fraud) class.
DEFAULT_FOCAL_ALPHA: float = 0.25

#: Focal loss γ — focusing parameter; higher → more weight on hard examples.
DEFAULT_FOCAL_GAMMA: float = 2.0

#: Adam learning rate.
DEFAULT_LR: float = 1e-3

#: L2 weight decay (Adam optimizer).
DEFAULT_WEIGHT_DECAY: float = 1e-4

#: Training batch size.
DEFAULT_BATCH_SIZE: int = 1024

#: Maximum training epochs.
DEFAULT_EPOCHS: int = 50

#: Early stopping patience (epochs without val AUC improvement).
DEFAULT_PATIENCE: int = 7


# ═══════════════════════════════════════════════════════════════════════════════
# Loss function
# ═══════════════════════════════════════════════════════════════════════════════


class FocalLoss(nn.Module):
    """Focal loss for training on severely class-imbalanced data.

    Introduced by Lin et al. (2017) and adopted in this paper to
    concentrate gradient mass on uncertain, minority-class (fraud)
    samples near the decision boundary:

        L_focal = −Σ [ α·y·(1−p̂)^γ·log(p̂)
                      + (1−α)·(1−y)·p̂^γ·log(1−p̂) ]

    The gradient with respect to the pre-sigmoid score s is (fraud class):

        ∂L/∂s = −α [ γ·(1−p̂)^(γ−1)·(−∂p̂/∂s)·log(p̂)
                    + (1−p̂)^γ·(1/p̂)·(∂p̂/∂s) ]

    where ∂p̂/∂s = p̂·(1−p̂).

    Paper reference (System Model section):
        "use a cost-sensitive logistic or focal loss on mini-batches …
        With α (class weight) and γ (focusing) tuned to concentrate
        gradient mass on minority fraud examples."

    Parameters
    ----------
    alpha : float, default 0.25
        Weighting factor for the minority (fraud, y=1) class.
        Complementary weight (1−alpha) is applied to the majority class.
    gamma : float, default 2.0
        Focusing parameter.  gamma=0 reduces to weighted cross-entropy.
        Higher values suppress the contribution of easy examples more
        aggressively.
    reduction : str, default "mean"
        Specifies the reduction to apply to the output: ``"none"`` |
        ``"mean"`` | ``"sum"``.
    """

    def __init__(
        self,
        alpha: float = DEFAULT_FOCAL_ALPHA,
        gamma: float = DEFAULT_FOCAL_GAMMA,
        reduction: str = "mean",
    ) -> None:
        super().__init__()
        if not 0.0 < alpha < 1.0:
            raise ValueError(f"alpha must be in (0, 1), got {alpha}.")
        if gamma < 0:
            raise ValueError(f"gamma must be >= 0, got {gamma}.")
        if reduction not in ("none", "mean", "sum"):
            raise ValueError(f"reduction must be 'none', 'mean', or 'sum'.")

        self.alpha     = alpha
        self.gamma     = gamma
        self.reduction = reduction

    def forward(self, logits: torch.Tensor, targets: torch.Tensor) -> torch.Tensor:
        """Compute focal loss between raw logits and binary targets.

        Parameters
        ----------
        logits : torch.Tensor, shape (N,) or (N, 1)
            Raw (pre-sigmoid) model outputs.
        targets : torch.Tensor, shape (N,)
            Binary ground-truth labels (0 or 1).

        Returns
        -------
        torch.Tensor
            Scalar loss value (if reduction != "none"), otherwise shape (N,).
        """
        logits  = logits.squeeze()
        targets = targets.float()

        p       = torch.sigmoid(logits)
        # p_t = p when y=1, (1-p) when y=0
        p_t     = p * targets + (1.0 - p) * (1.0 - targets)
        # alpha_t = alpha when y=1, (1-alpha) when y=0
        alpha_t = self.alpha * targets + (1.0 - self.alpha) * (1.0 - targets)

        # Focal modulating factor: (1 - p_t)^gamma
        focal_weight = (1.0 - p_t).pow(self.gamma)

        # Binary cross-entropy without reduction
        bce = -torch.log(p_t.clamp(min=1e-8))

        loss = alpha_t * focal_weight * bce

        if self.reduction == "mean":
            return loss.mean()
        if self.reduction == "sum":
            return loss.sum()
        return loss

    def extra_repr(self) -> str:
        return f"alpha={self.alpha}, gamma={self.gamma}, reduction={self.reduction!r}"


# ═══════════════════════════════════════════════════════════════════════════════
# Building blocks
# ═══════════════════════════════════════════════════════════════════════════════


class _DenseBlock(nn.Module):
    """Single fully-connected block: Linear → BatchNorm → ReLU → Dropout.

    Used internally by :class:`FraudDNNEncoder` to build the hidden layers.

    Parameters
    ----------
    in_features : int
        Number of input features.
    out_features : int
        Number of output features.
    dropout : float
        Dropout probability applied after the activation.
    """

    def __init__(self, in_features: int, out_features: int, dropout: float) -> None:
        super().__init__()
        self.block = nn.Sequential(
            nn.Linear(in_features, out_features, bias=False),  # bias absorbed by BN
            nn.BatchNorm1d(out_features),
            nn.ReLU(inplace=True),
            nn.Dropout(p=dropout),
        )

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.block(x)


# ═══════════════════════════════════════════════════════════════════════════════
# Main encoder
# ═══════════════════════════════════════════════════════════════════════════════


class FraudDNNEncoder(nn.Module):
    """Tabular DNN encoder — Stage 1 of the hybrid fraud detection pipeline.

    Maps a scaled feature vector x ∈ R^d to a compact latent embedding
    z ∈ R^k via a stack of fully-connected hidden layers followed by a
    dedicated embedding layer.  The embedding z is the *only* output
    consumed by Stage 2 (the gradient-boosted ensemble).  A lightweight
    classification head is attached solely for Stage 1 training and is
    discarded at inference time.

    Architecture
    ------------
    Input (d)
      │
      ▼
    DenseBlock_1 [in=d,  out=H_1]  ← Linear + BN + ReLU + Dropout
      │
      ▼
    DenseBlock_2 [in=H_1, out=H_2]
      │
      ▼
      …   (up to 5 blocks)
      │
      ▼
    DenseBlock_n [in=H_{n-1}, out=H_n]
      │
      ▼
    EmbeddingLayer [Linear + BN + ReLU]  →  z ∈ R^k  (Stage 2 input)
      │
      ▼
    ClassifierHead [Linear(k → 1)]  →  raw logit  (training only)

    Parameters
    ----------
    input_dim : int
        Dimensionality of the input feature vector (must match the output
        of ``preprocessing.py`` — typically 37 for the Credit Card dataset).
    hidden_dims : List[int], default [256, 128, 64]
        Width of each hidden DenseBlock.  The paper specifies "three to
        five fully connected hidden layers."
    embedding_dim : int, default 32
        Dimensionality of the latent embedding z.  This is the input size
        for the XGBoost/LightGBM ensemble head (ensemble.py).
    dropout : float, default 0.3
        Dropout probability applied after each hidden layer's ReLU.
    """

    def __init__(
        self,
        input_dim: int,
        hidden_dims: List[int] = DEFAULT_HIDDEN_DIMS,
        embedding_dim: int = DEFAULT_EMBEDDING_DIM,
        dropout: float = DEFAULT_DROPOUT,
    ) -> None:
        super().__init__()

        if len(hidden_dims) < 1:
            raise ValueError("hidden_dims must have at least one element.")
        if not 1 <= len(hidden_dims) <= 5:
            logger.warning(
                "Paper specifies 3–5 hidden layers; got %d.", len(hidden_dims)
            )

        self.input_dim     = input_dim
        self.hidden_dims   = list(hidden_dims)
        self.embedding_dim = embedding_dim
        self.dropout       = dropout

        # ── Hidden layers ─────────────────────────────────────────────────────
        blocks     = []
        prev_dim   = input_dim
        for h_dim in hidden_dims:
            blocks.append(_DenseBlock(prev_dim, h_dim, dropout))
            prev_dim = h_dim
        self.hidden_layers = nn.Sequential(*blocks)

        # ── Embedding layer (penultimate) — produces z ────────────────────────
        # Paper: "The second to last hidden layer produces an embedding of each
        # transaction, but it is compact, containing high level abstractions."
        self.embedding_layer = nn.Sequential(
            nn.Linear(prev_dim, embedding_dim, bias=False),
            nn.BatchNorm1d(embedding_dim),
            nn.ReLU(inplace=True),
        )

        # ── Classification head (training only) ───────────────────────────────
        # Removed at inference; SHAP runs on the ensemble (Stage 2), not here.
        self.classifier_head = nn.Linear(embedding_dim, 1)

        # ── Weight initialisation (Kaiming / He) ──────────────────────────────
        self._init_weights()

        logger.info(
            "FraudDNNEncoder built.  input=%d  hidden=%s  embedding=%d  "
            "dropout=%.2f  params=%s",
            input_dim,
            hidden_dims,
            embedding_dim,
            dropout,
            f"{self._count_params():,}",
        )

    # ── Forward passes ────────────────────────────────────────────────────────

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        """Full forward pass: raw features → logit (for training).

        Parameters
        ----------
        x : torch.Tensor, shape (B, input_dim)
            Batch of scaled input feature vectors.

        Returns
        -------
        torch.Tensor, shape (B, 1)
            Raw (pre-sigmoid) logit for the fraud class.
        """
        z = self.encode(x)
        return self.classifier_head(z)

    def encode(self, x: torch.Tensor) -> torch.Tensor:
        """Extract the latent embedding z — the Stage 2 input.

        This is the primary method called by ``ensemble.py`` after training
        to obtain the embedding vectors passed to XGBoost/LightGBM.

        Parameters
        ----------
        x : torch.Tensor, shape (B, input_dim)
            Batch of scaled input feature vectors.

        Returns
        -------
        torch.Tensor, shape (B, embedding_dim)
            Latent embedding z = φ_θ(x).
        """
        h = self.hidden_layers(x)
        z = self.embedding_layer(h)
        return z

    def predict_proba(self, x: torch.Tensor) -> torch.Tensor:
        """Return sigmoid fraud probabilities (for standalone DNN evaluation).

        Parameters
        ----------
        x : torch.Tensor, shape (B, input_dim)

        Returns
        -------
        torch.Tensor, shape (B,)
            Fraud probability p̂ ∈ (0, 1) for each transaction.
        """
        return torch.sigmoid(self.forward(x)).squeeze()

    # ── Batch embedding extraction (numpy in / numpy out) ────────────────────

    @torch.no_grad()
    def extract_embeddings(
        self,
        X: np.ndarray,
        batch_size: int = 4096,
        device: Optional[torch.device] = None,
    ) -> np.ndarray:
        """Extract embeddings for a full dataset in batches.

        Convenience wrapper that handles device placement, batch iteration,
        and conversion back to numpy.  Call this after training to get the
        embedding matrix Z passed to ``ensemble.py``.

        Parameters
        ----------
        X : np.ndarray, shape (N, input_dim)
            Scaled feature matrix (output of FoldPreprocessor).
        batch_size : int, default 4096
            Number of rows processed per forward pass.  Increase for speed
            on GPU; decrease if you hit out-of-memory errors.
        device : torch.device, optional
            Target device.  Defaults to the device of the model's first
            parameter.

        Returns
        -------
        np.ndarray, shape (N, embedding_dim)
            Embedding matrix Z where row i is z_i = φ_θ(x_i).

        Examples
        --------
        >>> Z_train = model.extract_embeddings(X_train)
        >>> Z_val   = model.extract_embeddings(X_val)
        >>> # Now train XGBoost on Z_train, evaluate on Z_val
        """
        if device is None:
            device = next(self.parameters()).device

        self.eval()
        parts: List[np.ndarray] = []
        X_tensor = torch.from_numpy(X.astype(np.float32))

        for start in range(0, len(X), batch_size):
            batch = X_tensor[start : start + batch_size].to(device)
            z     = self.encode(batch).cpu().numpy()
            parts.append(z)

        return np.vstack(parts)

    # ── Persistence ───────────────────────────────────────────────────────────

    def save(self, path: str | Path) -> None:
        """Save model weights and construction hyperparameters to disk.

        Saves both the ``state_dict`` (weights) *and* the constructor
        arguments so that :meth:`load` can reconstruct the exact
        architecture without the caller needing to remember the
        hyperparameters.

        Parameters
        ----------
        path : str or Path
            Destination ``.pt`` file, e.g. ``results/models/dnn_fold0.pt``.
        """
        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        torch.save(
            {
                "state_dict"   : self.state_dict(),
                "input_dim"    : self.input_dim,
                "hidden_dims"  : self.hidden_dims,
                "embedding_dim": self.embedding_dim,
                "dropout"      : self.dropout,
            },
            path,
        )
        logger.info("Model saved to %s", path)

    @classmethod
    def load(
        cls,
        path: str | Path,
        device: Optional[torch.device] = None,
        # Kept for backwards-compat; ignored when checkpoint stores hparams
        input_dim: Optional[int] = None,
    ) -> "FraudDNNEncoder":
        """Load a saved model from disk.

        Parameters
        ----------
        path : str or Path
            Path to a ``.pt`` file saved by :meth:`save`.
        device : torch.device, optional
            Device to load the model onto.  Defaults to CPU.
        input_dim : int, optional
            Ignored if the checkpoint stores architecture hyperparameters
            (files saved with this version of the code).  Provided for
            compatibility with older checkpoints that stored only
            ``state_dict``.

        Returns
        -------
        FraudDNNEncoder
            Reconstructed model in eval mode.
        """
        if device is None:
            device = torch.device("cpu")

        checkpoint = torch.load(path, map_location=device)

        if "input_dim" in checkpoint:
            # New-style checkpoint: hyperparams stored alongside weights
            model = cls(
                input_dim    = checkpoint["input_dim"],
                hidden_dims  = checkpoint["hidden_dims"],
                embedding_dim= checkpoint["embedding_dim"],
                dropout      = checkpoint["dropout"],
            )
        else:
            # Legacy checkpoint: state_dict only
            if input_dim is None:
                raise ValueError(
                    "This checkpoint does not store architecture hyperparameters. "
                    "Pass input_dim explicitly."
                )
            model = cls(input_dim=input_dim)

        model.load_state_dict(checkpoint["state_dict"])
        model.to(device)
        model.eval()
        logger.info("Model loaded from %s  (device=%s)", path, device)
        return model

    # ── Helpers ───────────────────────────────────────────────────────────────

    def _init_weights(self) -> None:
        """Initialise Linear layers with Kaiming uniform (He initialisation).

        Kaiming initialisation is the standard choice for networks with
        ReLU activations; it keeps the variance of activations constant
        across layers, which speeds up convergence.
        """
        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.kaiming_uniform_(m.weight, nonlinearity="relu")
                if m.bias is not None:
                    nn.init.zeros_(m.bias)
            elif isinstance(m, nn.BatchNorm1d):
                nn.init.ones_(m.weight)
                nn.init.zeros_(m.bias)

    def _count_params(self) -> int:
        """Return the total number of trainable parameters."""
        return sum(p.numel() for p in self.parameters() if p.requires_grad)

    def __repr__(self) -> str:
        return (
            f"FraudDNNEncoder("
            f"input={self.input_dim}, "
            f"hidden={self.hidden_dims}, "
            f"embedding={self.embedding_dim}, "
            f"dropout={self.dropout}, "
            f"params={self._count_params():,})"
        )



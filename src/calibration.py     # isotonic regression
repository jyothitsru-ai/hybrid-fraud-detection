def expected_calibration_error(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    n_bins: int = DEFAULT_N_BINS,
    strategy: str = "uniform",
) -> float:
    """Expected Calibration Error (ECE) as a percentage.

    ECE measures the average gap between predicted confidence and observed
    accuracy across probability bins:

        ECE = sum_b (|B_b| / N) * |acc_b - conf_b|

    where B_b are the samples in bin b, acc_b is the fraction of true
    positives in bin b, and conf_b is the mean predicted probability.

    Paper Table 2 target values:
        Credit Card:  pre=6.1%  post=2.0%
        IEEE-CIS:     pre=7.5%  post=2.5%
        PaySim:       pre=5.8%  post=1.9%

    Parameters
    ----------
    y_true : np.ndarray, shape (N,)
        Binary ground-truth labels (0=legit, 1=fraud).
    y_prob : np.ndarray, shape (N,)
        Predicted fraud probabilities in [0, 1].
    n_bins : int, default 10
        Number of probability bins.
    strategy : {"uniform", "quantile"}, default "uniform"
        "uniform"  — equal-width bins over [0, 1].
        "quantile" — bins with equal numbers of samples (better for
                     skewed score distributions in imbalanced data).

    Returns
    -------
    float
        ECE as a percentage (e.g. 6.1 means 6.1%).
    """
    y_true = np.asarray(y_true).ravel()
    y_prob = np.asarray(y_prob).ravel()

    if strategy == "uniform":
        bin_edges = np.linspace(0.0, 1.0, n_bins + 1)
    elif strategy == "quantile":
        bin_edges = np.quantile(y_prob, np.linspace(0.0, 1.0, n_bins + 1))
        bin_edges = np.unique(bin_edges)  # deduplicate
    else:
        raise ValueError(f"strategy must be 'uniform' or 'quantile', got {strategy!r}.")

    ece = 0.0
    n   = len(y_true)
    for lo, hi in zip(bin_edges[:-1], bin_edges[1:]):
        mask = (y_prob >= lo) & (y_prob < hi)
        if mask.sum() == 0:
            continue
        acc  = float(y_true[mask].mean())
        conf = float(y_prob[mask].mean())
        ece += (mask.sum() / n) * abs(acc - conf)

    return ece * 100.0


def maximum_calibration_error(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    n_bins: int = DEFAULT_N_BINS,
) -> float:
    """Maximum Calibration Error (MCE) as a percentage.

    MCE is the *worst-case* bin-level miscalibration, complementing ECE's
    average-case view:

        MCE = max_b |acc_b - conf_b|

    Useful for identifying specific probability regions where the model is
    systematically wrong — which matters in fraud because decisions near
    tau* are the most sensitive to miscalibration.

    Parameters
    ----------
    y_true : np.ndarray, shape (N,)
    y_prob : np.ndarray, shape (N,)
    n_bins : int, default 10

    Returns
    -------
    float
        MCE as a percentage.
    """
    bin_edges = np.linspace(0.0, 1.0, n_bins + 1)
    mce = 0.0
    for lo, hi in zip(bin_edges[:-1], bin_edges[1:]):
        mask = (y_prob >= lo) & (y_prob < hi)
        if mask.sum() == 0:
            continue
        acc  = float(y_true[mask].mean())
        conf = float(y_prob[mask].mean())
        mce  = max(mce, abs(acc - conf))
    return mce * 100.0


def overconfidence_score(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    n_bins: int = DEFAULT_N_BINS,
) -> float:
    """Signed ECE: positive means overconfident, negative means underconfident.

    A model predicting fraud too confidently (conf > acc) will place the
    effective operating point above tau*, pushing recall down.  A model
    that is underconfident will place the operating point below tau*,
    increasing false alarms.  This score makes the direction explicit.

    Parameters
    ----------
    y_true : np.ndarray
    y_prob : np.ndarray
    n_bins : int

    Returns
    -------
    float
        Signed calibration gap (%).  Positive = overconfident.
    """
    bin_edges = np.linspace(0.0, 1.0, n_bins + 1)
    signed_ece = 0.0
    n = len(y_true)
    for lo, hi in zip(bin_edges[:-1], bin_edges[1:]):
        mask = (y_prob >= lo) & (y_prob < hi)
        if mask.sum() == 0:
            continue
        acc  = float(y_true[mask].mean())
        conf = float(y_prob[mask].mean())
        signed_ece += (mask.sum() / n) * (conf - acc)   # positive = over
    return signed_ece * 100.0


def reliability_curve(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    n_bins: int = DEFAULT_N_BINS,
    strategy: str = "uniform",
) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """Compute reliability curve data (fraction of positives vs mean confidence).

    Parameters
    ----------
    y_true : np.ndarray
    y_prob : np.ndarray
    n_bins : int
    strategy : str

    Returns
    -------
    fraction_of_positives : np.ndarray
        Observed fraud rate per bin (y-axis of reliability diagram).
    mean_predicted : np.ndarray
        Mean predicted probability per bin (x-axis).
    bin_counts : np.ndarray
        Number of samples per bin (for bar histogram overlay).
    """
    frac_pos, mean_pred = calibration_curve(
        y_true, y_prob, n_bins=n_bins, strategy=strategy
    )
    bin_edges = np.linspace(0.0, 1.0, n_bins + 1)
    bin_counts = np.array([
        int(((y_prob >= lo) & (y_prob < hi)).sum())
        for lo, hi in zip(bin_edges[:-1], bin_edges[1:])
    ])
    return frac_pos, mean_pred, bin_counts



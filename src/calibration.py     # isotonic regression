# Cross-fold calibration summary (Table 2 reproduction)
# ═══════════════════════════════════════════════════════════════════════════════


def summarise_cross_fold_calibration(
    reports: List[CalibrationReport],
) -> pd.DataFrame:
    """Aggregate calibration metrics across folds into a Table 2 summary.

    Parameters
    ----------
    reports : List[CalibrationReport]
        One report per cross-validation fold.

    Returns
    -------
    pd.DataFrame
        Mean ± std for each metric across folds, formatted to match
        Table 2 in the paper.
    """
    rows = [r.to_dict() for r in reports]
    df   = pd.DataFrame(rows)

    numeric_cols = [
        "ece_before_pct", "ece_after_pct", "ece_delta_pp",
        "mce_before_pct", "mce_after_pct",
        "brier_before", "brier_after", "brier_delta",
        "overconf_before", "overconf_after",
    ]

    summary_rows = []
    for col in numeric_cols:
        vals = df[col].values
        summary_rows.append({
            "metric": col,
            "mean"  : round(float(vals.mean()), 4),
            "std"   : round(float(vals.std()),  4),
            "min"   : round(float(vals.min()),  4),
            "max"   : round(float(vals.max()),  4),
        })

    summary_df = pd.DataFrame(summary_rows).set_index("metric")
    logger.info(
        "Cross-fold calibration summary (%d folds):\n"
        "  ECE   %s%.2f ± %.2f%%  (before)  →  %.2f ± %.2f%%  (after)\n"
        "  Brier  %.4f ± %.4f  (before)  →  %.4f ± %.4f  (after)",
        len(reports),
        "",
        summary_df.loc["ece_before_pct", "mean"],
        summary_df.loc["ece_before_pct", "std"],
        summary_df.loc["ece_after_pct",  "mean"],
        summary_df.loc["ece_after_pct",  "std"],
        summary_df.loc["brier_before",   "mean"],
        summary_df.loc["brier_before",   "std"],
        summary_df.loc["brier_after",    "mean"],
        summary_df.loc["brier_after",    "std"],
    )
    return summary_df



# Threshold optimisation
# ═══════════════════════════════════════════════════════════════════════════════


def find_cost_optimal_threshold(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    cost_fn: float = DEFAULT_COST_FN,
    cost_fp: float = DEFAULT_COST_FP,
    n_grid: int = 1000,
) -> Tuple[float, float]:
    """Find the empirically optimal threshold by grid-searching the cost curve.

    The analytical tau* = c_FP / (c_FP + c_FN) (Lemma 1) assumes perfect
    calibration.  This function also searches empirically over a fine grid
    to find the threshold that minimises actual cost on the validation set,
    which may differ slightly from the analytical value due to residual
    miscalibration.

    Parameters
    ----------
    y_true : np.ndarray, shape (N,)
    y_prob : np.ndarray, shape (N,)
        Calibrated fraud probabilities.
    cost_fn : float
        Cost of a false negative (missed fraud).
    cost_fp : float
        Cost of a false positive (false alarm).
    n_grid : int, default 1000
        Number of threshold values to evaluate.

    Returns
    -------
    tau_analytical : float
        Lemma 1 analytical threshold = c_FP / (c_FP + c_FN).
    tau_empirical : float
        Grid-search threshold that minimised cost on y_true.
    """
    tau_analytical = cost_fp / (cost_fp + cost_fn)
    thresholds     = np.linspace(0.001, 0.999, n_grid)
    costs          = []

    for tau in thresholds:
        y_pred = (y_prob >= tau).astype(int)
        fn = int(((y_true == 1) & (y_pred == 0)).sum())
        fp = int(((y_true == 0) & (y_pred == 1)).sum())
        costs.append(fn * cost_fn + fp * cost_fp)

    tau_empirical = float(thresholds[np.argmin(costs)])
    logger.info(
        "Threshold search: analytical τ*=%.4f  empirical τ*=%.4f  "
        "(gap=%.4f)  cost_ratio=%.0f:1",
        tau_analytical, tau_empirical,
        abs(tau_analytical - tau_empirical),
        cost_fn / cost_fp,
    )
    return tau_analytical, tau_empirical


def plot_cost_threshold_curve(
    y_true: np.ndarray,
    probs_before: np.ndarray,
    probs_after: np.ndarray,
    cost_fn: float = DEFAULT_COST_FN,
    cost_fp: float = DEFAULT_COST_FP,
    tau_star: Optional[float] = None,
    dataset_name: str = "",
    save_path: Optional[str | Path] = None,
    show: bool = True,
) -> plt.Figure:
    """Plot expected cost vs. decision threshold before and after calibration.

    Shows the paper's key finding: calibration shifts and sharpens the
    cost minimum, enabling a more precisely placed operating point.

    "The hybrid sets its threshold to minimize the expected loss and ...
    the threshold of the hybrid reduces the cost per 100,000 transactions
    by a percentage in the double-digits."  (Calibration Analysis section)

    Parameters
    ----------
    y_true : np.ndarray, shape (N,)
    probs_before : np.ndarray, shape (N,)
        Raw uncalibrated probabilities.
    probs_after : np.ndarray, shape (N,)
        Calibrated probabilities.
    cost_fn : float
    cost_fp : float
    tau_star : float, optional
        If provided, draw a vertical line at this threshold.
    dataset_name : str
    save_path : str or Path, optional
    show : bool, default True

    Returns
    -------
    plt.Figure
    """
    thresholds = np.linspace(0.001, 0.5, 500)   # focus on low-threshold region

    def cost_curve(probs: np.ndarray) -> np.ndarray:
        result = []
        for tau in thresholds:
            y_pred = (probs >= tau).astype(int)
            fn = int(((y_true == 1) & (y_pred == 0)).sum())
            fp = int(((y_true == 0) & (y_pred == 1)).sum())
            result.append((fn * cost_fn + fp * cost_fp) / len(y_true) * 100_000)
        return np.array(result)

    costs_before = cost_curve(probs_before)
    costs_after  = cost_curve(probs_after)

    best_before = float(costs_before.min())
    best_after  = float(costs_after.min())
    saving_pct  = (best_before - best_after) / best_before * 100

    fig, ax = plt.subplots(figsize=(11, 5))
    ax.plot(thresholds, costs_before, label=f"Before calibration (min={best_before:.1f})",
            color="#E63946", linewidth=1.5, alpha=0.9)
    ax.plot(thresholds, costs_after,  label=f"After calibration  (min={best_after:.1f})",
            color="#2DC653", linewidth=2.2)

    if tau_star is not None:
        ax.axvline(tau_star, color="#1D3557", linestyle="--", linewidth=1.2,
                   label=f"τ* = {tau_star:.4f}  (analytical)")

    # Mark minima
    ax.scatter(
        thresholds[np.argmin(costs_before)], best_before,
        color="#E63946", s=60, zorder=5,
    )
    ax.scatter(
        thresholds[np.argmin(costs_after)], best_after,
        color="#2DC653", s=60, zorder=5,
    )

    ax.set_xlabel("Decision threshold τ", fontsize=11)
    ax.set_ylabel("Expected cost per 100,000 transactions", fontsize=11)
    ax.set_title(
        f"Cost-Sensitive Threshold Analysis — {dataset_name}\n"
        f"Calibration saves {saving_pct:.1f}% in expected cost  "
        f"(c_FN={cost_fn:.0f}, c_FP={cost_fp:.0f})",
        fontsize=11, fontweight="bold",
    )
    ax.legend(fontsize=10)
    ax.set_xlim(0, thresholds[-1])

    plt.tight_layout()
    if save_path:
        Path(save_path).parent.mkdir(parents=True, exist_ok=True)
        fig.savefig(save_path, bbox_inches="tight")
        logger.info("Cost-threshold curve saved to %s", save_path)
    if show:
        plt.show()
    return fig



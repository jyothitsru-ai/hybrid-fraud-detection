class IsotonicCalibrator(CalibrationBase):
    """Post-hoc isotonic regression calibration — the paper's primary method.

    Isotonic regression fits a non-decreasing step function mapping
    raw scores to empirical fraud rates.  It is non-parametric and makes
    no distributional assumptions, making it robust to the severe class
    imbalance in fraud data.

    Paper reference:
        "An isotonic regressor with the latest validation window is used
        to score-calibrate the scores so they match the observed
        frequencies."  (Proposed Architecture section)

        "Calibrating the probability post-hoc based on isotonic regression
        that was trained on the validation folds was a vital step of the
        pipeline."  (Experimental Datasets section)

        "isotonic regression reduced the predicted error of calibration by
        more than six to less than two percent in all four datasets."
        (Results Discussion)

    Parameters
    ----------
    out_of_bounds : {"clip", "raise", "nan"}, default "clip"
        Behaviour when transform() receives scores outside the training
        range.  "clip" clamps to [min_train, max_train] — recommended for
        production where score distributions can shift.
    """

    name = "isotonic"

    def __init__(self, out_of_bounds: str = "clip") -> None:
        self.out_of_bounds = out_of_bounds
        self._iso: Optional[IsotonicRegression] = None

    def fit(
        self,
        raw_probs: np.ndarray,
        y_true: np.ndarray,
    ) -> "IsotonicCalibrator":
        """Fit isotonic regression on validation fold raw scores.

        Parameters
        ----------
        raw_probs : np.ndarray, shape (N,)
            Uncalibrated fraud probabilities.
        y_true : np.ndarray, shape (N,)
            Binary labels.

        Returns
        -------
        self
        """
        raw_probs = np.asarray(raw_probs, dtype=np.float64).ravel()
        y_true    = np.asarray(y_true,    dtype=np.float64).ravel()

        if len(raw_probs) != len(y_true):
            raise ValueError(
                f"raw_probs length {len(raw_probs)} != y_true length {len(y_true)}."
            )
        if y_true.sum() == 0:
            raise ValueError("y_true contains no positive (fraud) labels.")

        self._iso = IsotonicRegression(
            out_of_bounds=self.out_of_bounds,
            increasing=True,
        )
        self._iso.fit(raw_probs, y_true)
        logger.info(
            "IsotonicCalibrator fitted on %d samples  "
            "(fraud=%.3f%%  score_range=[%.4f, %.4f])",
            len(raw_probs),
            y_true.mean() * 100,
            raw_probs.min(),
            raw_probs.max(),
        )
        return self

    def transform(self, raw_probs: np.ndarray) -> np.ndarray:
        """Apply fitted isotonic mapping to new raw scores.

        Parameters
        ----------
        raw_probs : np.ndarray, shape (N,)

        Returns
        -------
        np.ndarray, shape (N,)
            Calibrated probabilities clipped to [0, 1].
        """
        if self._iso is None:
            raise RuntimeError("IsotonicCalibrator has not been fitted. Call fit() first.")
        raw_probs = np.asarray(raw_probs, dtype=np.float64).ravel()
        cal = self._iso.predict(raw_probs)
        return np.clip(cal, 0.0, 1.0).astype(np.float32)

    def save(self, path: str | Path) -> None:
        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        joblib.dump({"calibrator": self._iso, "out_of_bounds": self.out_of_bounds}, path)
        logger.info("IsotonicCalibrator saved to %s", path)

    @classmethod
    def load(cls, path: str | Path) -> "IsotonicCalibrator":
        ckpt = joblib.load(path)
        obj  = cls(out_of_bounds=ckpt["out_of_bounds"])
        obj._iso = ckpt["calibrator"]
        logger.info("IsotonicCalibrator loaded from %s", path)
        return obj

    def __repr__(self) -> str:
        fitted = self._iso is not None
        return f"IsotonicCalibrator(fitted={fitted}, out_of_bounds={self.out_of_bounds!r})"


class PlattCalibrator(CalibrationBase):
    """Platt scaling (logistic calibration) for comparison with isotonic.

    Fits a two-parameter logistic function a*s + b to map raw scores s
    to calibrated probabilities p = sigma(a*s + b).  More parametric
    and less flexible than isotonic regression; provided as a baseline
    comparator.

    Paper: "Post-hoc calibration (e.g., isotonic or Platt scaling on a
    validation stream) yields p_tilde(x) close to P(A|B)."
    (Calibration and operating point section)

    Parameters
    ----------
    C : float, default 1.0
        Inverse regularisation strength for the underlying logistic
        regression.  Smaller values = stronger regularisation.
    """

    name = "platt"

    def __init__(self, C: float = 1.0) -> None:
        self.C = C
        self._lr: Optional[LogisticRegression] = None

    def fit(self, raw_probs: np.ndarray, y_true: np.ndarray) -> "PlattCalibrator":
        """Fit logistic regression on raw scores.

        Parameters
        ----------
        raw_probs : np.ndarray, shape (N,)
        y_true : np.ndarray, shape (N,)

        Returns
        -------
        self
        """
        raw_probs = np.asarray(raw_probs).ravel().reshape(-1, 1)
        y_true    = np.asarray(y_true).ravel()

        self._lr = LogisticRegression(C=self.C, solver="lbfgs", max_iter=1000)
        self._lr.fit(raw_probs, y_true)
        logger.info(
            "PlattCalibrator fitted.  a=%.4f  b=%.4f",
            float(self._lr.coef_[0][0]),
            float(self._lr.intercept_[0]),
        )
        return self

    def transform(self, raw_probs: np.ndarray) -> np.ndarray:
        if self._lr is None:
            raise RuntimeError("PlattCalibrator has not been fitted. Call fit() first.")
        X = np.asarray(raw_probs).ravel().reshape(-1, 1)
        return self._lr.predict_proba(X)[:, 1].astype(np.float32)

    @property
    def coef_a(self) -> float:
        """Platt scaling slope parameter a."""
        return float(self._lr.coef_[0][0]) if self._lr else float("nan")

    @property
    def coef_b(self) -> float:
        """Platt scaling intercept parameter b."""
        return float(self._lr.intercept_[0]) if self._lr else float("nan")

    def save(self, path: str | Path) -> None:
        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        joblib.dump({"lr": self._lr, "C": self.C}, path)
        logger.info("PlattCalibrator saved to %s", path)

    @classmethod
    def load(cls, path: str | Path) -> "PlattCalibrator":
        ckpt = joblib.load(path)
        obj  = cls(C=ckpt["C"])
        obj._lr = ckpt["lr"]
        return obj

    def __repr__(self) -> str:
        if self._lr is not None:
            return f"PlattCalibrator(a={self.coef_a:.4f}, b={self.coef_b:.4f}, C={self.C})"
        return f"PlattCalibrator(fitted=False, C={self.C})"


class TemperatureCalibrator(CalibrationBase):
    """Temperature scaling — a single-parameter calibration method.

    Divides the pre-sigmoid logit by a learned scalar temperature T:

        p_cal = sigma(logit(s) / T)

    T > 1 softens (reduces overconfidence); T < 1 sharpens predictions.
    Very fast at inference time (one division) and easy to audit — useful
    for the paper's real-time serving context where SHAP is generated
    asynchronously while the fraud decision must meet single-digit
    millisecond latency.

    Parameters
    ----------
    init_T : float, default 1.5
        Initial temperature before optimisation.
    """

    name = "temperature"

    def __init__(self, init_T: float = 1.5) -> None:
        self.init_T = init_T
        self.T_: Optional[float] = None

    def fit(
        self,
        raw_probs: np.ndarray,
        y_true: np.ndarray,
    ) -> "TemperatureCalibrator":
        """Fit temperature T by minimising negative log-likelihood.

        Parameters
        ----------
        raw_probs : np.ndarray, shape (N,)
        y_true : np.ndarray, shape (N,)

        Returns
        -------
        self
        """
        raw_probs = np.asarray(raw_probs, dtype=np.float64).ravel()
        y_true    = np.asarray(y_true,    dtype=np.float64).ravel()

        # Convert probabilities back to logits: logit(p) = log(p / (1-p))
        eps    = 1e-7
        logits = np.log(
            np.clip(raw_probs, eps, 1 - eps)
            / np.clip(1 - raw_probs, eps, 1 - eps)
        )

        def nll(T: float) -> float:
            """Negative log-likelihood under temperature T."""
            if T <= 0:
                return 1e12
            p_cal = sigmoid(logits / T)
            p_cal = np.clip(p_cal, eps, 1 - eps)
            return -float(
                (y_true * np.log(p_cal) + (1 - y_true) * np.log(1 - p_cal)).mean()
            )

        result  = minimize_scalar(nll, bounds=(0.01, 20.0), method="bounded")
        self.T_ = float(result.x)

        logger.info(
            "TemperatureCalibrator fitted.  T=%.4f  (init=%.4f)",
            self.T_, self.init_T,
        )
        return self

    def transform(self, raw_probs: np.ndarray) -> np.ndarray:
        if self.T_ is None:
            raise RuntimeError(
                "TemperatureCalibrator has not been fitted. Call fit() first."
            )
        raw_probs = np.asarray(raw_probs, dtype=np.float64).ravel()
        eps    = 1e-7
        logits = np.log(
            np.clip(raw_probs, eps, 1 - eps)
            / np.clip(1 - raw_probs, eps, 1 - eps)
        )
        return sigmoid(logits / self.T_).astype(np.float32)

    def save(self, path: str | Path) -> None:
        path = Path(path)
        path.parent.mkdir(parents=True, exist_ok=True)
        joblib.dump({"T": self.T_, "init_T": self.init_T}, path)
        logger.info("TemperatureCalibrator saved to %s (T=%.4f)", path, self.T_)

    @classmethod
    def load(cls, path: str | Path) -> "TemperatureCalibrator":
        ckpt = joblib.load(path)
        obj  = cls(init_T=ckpt["init_T"])
        obj.T_ = ckpt["T"]
        return obj

    def __repr__(self) -> str:
        return (
            f"TemperatureCalibrator("
            f"T={self.T_ if self.T_ is not None else 'unfitted'}, "
            f"init_T={self.init_T})"
        )



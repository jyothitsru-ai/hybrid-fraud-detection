# Abstract base class
# ═══════════════════════════════════════════════════════════════════════════════


class CalibrationBase(ABC):
    """Abstract interface shared by all calibrators in this module.

    Subclasses must implement :meth:`fit` and :meth:`transform`.
    The :meth:`fit_transform` convenience method is provided here.
    """

    #: Short human-readable name used in reports and plots.
    name: str = "base"

    @abstractmethod
    def fit(self, raw_probs: np.ndarray, y_true: np.ndarray) -> "CalibrationBase":
        """Fit the calibrator on raw scores and ground-truth labels.

        Parameters
        ----------
        raw_probs : np.ndarray, shape (N,)
            Uncalibrated fraud probabilities from the ensemble head.
        y_true : np.ndarray, shape (N,)
            Binary ground-truth labels.

        Returns
        -------
        self
        """

    @abstractmethod
    def transform(self, raw_probs: np.ndarray) -> np.ndarray:
        """Map raw probabilities to calibrated probabilities.

        Parameters
        ----------
        raw_probs : np.ndarray, shape (N,)

        Returns
        -------
        np.ndarray, shape (N,)
            Calibrated probabilities in [0, 1].
        """

    def fit_transform(
        self,
        raw_probs: np.ndarray,
        y_true: np.ndarray,
    ) -> np.ndarray:
        """Fit and immediately transform the same data.

        Convenience wrapper: fits the calibrator and returns calibrated
        probabilities in one call.

        Parameters
        ----------
        raw_probs : np.ndarray, shape (N,)
        y_true : np.ndarray, shape (N,)

        Returns
        -------
        np.ndarray, shape (N,)
        """
        return self.fit(raw_probs, y_true).transform(raw_probs)

    @abstractmethod
    def save(self, path: str | Path) -> None:
        """Persist the fitted calibrator to disk."""

    @classmethod
    @abstractmethod
    def load(cls, path: str | Path) -> "CalibrationBase":
        """Load a saved calibrator from disk."""



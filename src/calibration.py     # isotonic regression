        "platt"      : PlattCalibrator,
        "temperature": TemperatureCalibrator,
    }

    # Late imports to avoid circular dependencies
    from src.ensemble import EnsembleHead
    from src.model    import FraudDNNEncoder

    processed_dir = Path(args.processed_dir)
    models_dir    = Path(args.models_dir)

    fold_data = joblib.load(processed_dir / "fold_data.pkl")
    n_folds   = len(fold_data)

    dnn_models = [
        FraudDNNEncoder.load(models_dir / f"dnn_fold{k}.pt")
        for k in range(n_folds)
    ]
    ensemble_heads = [
        EnsembleHead.load(models_dir / f"ensemble_{args.backend}_fold{k}.pkl")
        for k in range(n_folds)
    ]

    print(
        f"Loaded {n_folds} folds  |  "
        f"backend={args.backend}  |  "
        f"calibrator={args.calibrator}  |  "
        f"τ*={args.cost_fp / (args.cost_fp + args.cost_fn):.4f}"
    )

    reports, summary_df = run_calibration_pipeline(
        fold_data        = fold_data,
        dnn_models       = dnn_models,
        ensemble_heads   = ensemble_heads,
        calibrator_class = calibrator_map[args.calibrator],
        dataset_name     = args.dataset,
        figures_dir      = args.figures_dir,
        models_dir       = args.models_dir,
        cost_fn          = args.cost_fn,
        cost_fp          = args.cost_fp,
    )

    print(f"\nCross-fold summary ({args.dataset}):")
    print(summary_df[["mean", "std"]].to_string())
    print(f"\nAll figures saved to {args.figures_dir}/")

# Full pipeline helper
# ═══════════════════════════════════════════════════════════════════════════════


def run_calibration_pipeline(
    fold_data: List[dict],
    dnn_models: List,
    ensemble_heads: List,
    calibrator_class: type = IsotonicCalibrator,
    dataset_name: str = "Credit Card",
    figures_dir: str | Path = "results/figures",
    models_dir: str | Path = "results/models",
    cost_fn: float = DEFAULT_COST_FN,
    cost_fp: float = DEFAULT_COST_FP,
    n_bins: int = DEFAULT_N_BINS,
) -> Tuple[List[CalibrationReport], pd.DataFrame]:
    """Run the full calibration analysis pipeline across all folds.

    For each fold:
    1. Extract DNN embeddings.
    2. Get raw uncalibrated probabilities from the ensemble head.
    3. Fit the chosen calibrator on the validation fold.
    4. Get calibrated probabilities.
    5. Build a CalibrationReport and produce all figures.

    After all folds:
    6. Aggregate into a cross-fold summary table (Table 2 format).

    Parameters
    ----------
    fold_data : List[dict]
        Output of preprocessing.run_pipeline().
    dnn_models : List[FraudDNNEncoder]
        Trained DNN encoders from model.train_all_folds().
    ensemble_heads : List[EnsembleHead]
        Fitted ensemble heads from ensemble.train_all_folds().
    calibrator_class : type, default IsotonicCalibrator
        The calibrator class to instantiate per fold.
    dataset_name : str
    figures_dir : str or Path
    models_dir : str or Path
    cost_fn : float
    cost_fp : float
    n_bins : int

    Returns
    -------
    reports : List[CalibrationReport]
    summary_df : pd.DataFrame
        Cross-fold summary in Table 2 format.
    """
    figures_dir = Path(figures_dir)
    models_dir  = Path(models_dir)
    figures_dir.mkdir(parents=True, exist_ok=True)

    tau_star = cost_fp / (cost_fp + cost_fn)
    reports: List[CalibrationReport] = []

    for fold_idx, (fold, dnn, head) in enumerate(
        zip(fold_data, dnn_models, ensemble_heads)
    ):
        logger.info("═══ Calibration Fold %d/%d ═══", fold_idx + 1, len(fold_data))

        Z_val  = dnn.extract_embeddings(fold["X_val"])
        y_val  = fold["y_val"]

        # Raw scores from ensemble (already available via head)
        raw_probs = head.predict_proba_uncalibrated(Z_val)

        # Fit calibrator on this fold's validation scores
        Z_train    = dnn.extract_embeddings(fold["X_train"])
        raw_train  = head.predict_proba_uncalibrated(Z_train)
        cal        = calibrator_class()
        cal.fit(raw_train, fold["y_train"])

        cal_probs = cal.transform(raw_probs)

        # Build report
        report = CalibrationReport.build(
            y_true          = y_val,
            probs_before    = raw_probs,
            probs_after     = cal_probs,
            dataset_name    = dataset_name,
            calibrator_name = cal.name,
            n_bins          = n_bins,
        )
        reports.append(report)
        logger.info("%s", report.summary())

        # Reliability diagrams + score histograms + metric bars
        report.plot(
            save_path=figures_dir / f"calibration_{dataset_name.replace(' ','_').lower()}_fold{fold_idx}.png",
            show=False,
        )

        # Cost-threshold curve
        plot_cost_threshold_curve(
            y_val, raw_probs, cal_probs,
            cost_fn=cost_fn, cost_fp=cost_fp,
            tau_star=tau_star,
            dataset_name=f"{dataset_name} (fold {fold_idx + 1})",
            save_path=figures_dir / f"cost_threshold_{dataset_name.replace(' ','_').lower()}_fold{fold_idx}.png",
            show=False,
        )

        # Save calibrator
        cal.save(models_dir / f"calibrator_{cal.name}_fold{fold_idx}.pkl")

        # Log threshold comparison
        tau_a, tau_e = find_cost_optimal_threshold(y_val, cal_probs, cost_fn, cost_fp)
        logger.info(
            "  τ* analytical=%.4f  τ* empirical=%.4f  gap=%.4f",
            tau_a, tau_e, abs(tau_a - tau_e),
        )

    summary_df = summarise_cross_fold_calibration(reports)
    summary_df.to_csv(figures_dir / f"calibration_summary_{dataset_name.replace(' ','_').lower()}.csv")
    logger.info("Calibration pipeline complete.  Summary saved.")

    return reports, summary_df



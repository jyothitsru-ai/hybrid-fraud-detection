@dataclass
class CalibrationReport:
    """Structured calibration analysis result for a single fold/dataset.

    Captures all metrics from Table 2 plus additional diagnostics and
    provides plotting and serialisation methods.

    Attributes
    ----------
    dataset_name : str
        Human-readable dataset identifier (e.g. "Credit Card", "IEEE-CIS").
    calibrator_name : str
        Name of the calibrator used.
    n_samples : int
        Number of validation samples evaluated.
    fraud_rate : float
        Observed fraud rate in the validation set.
    ece_before : float
        ECE (%) using raw uncalibrated scores.
    ece_after : float
        ECE (%) using calibrated scores.
    mce_before : float
        MCE (%) before calibration.
    mce_after : float
        MCE (%) after calibration.
    brier_before : float
        Brier score before calibration.
    brier_after : float
        Brier score after calibration.
    overconf_before : float
        Signed overconfidence (%) before calibration.
    overconf_after : float
        Signed overconfidence (%) after calibration.
    roc_auc_preserved : bool
        Whether ROC-AUC was preserved within 0.001 after calibration
        (paper: "calibration preserves AUC").
    """

    dataset_name       : str   = ""
    calibrator_name    : str   = "isotonic"
    n_samples          : int   = 0
    fraud_rate         : float = 0.0
    ece_before         : float = 0.0
    ece_after          : float = 0.0
    mce_before         : float = 0.0
    mce_after          : float = 0.0
    brier_before       : float = 0.0
    brier_after        : float = 0.0
    overconf_before    : float = 0.0
    overconf_after     : float = 0.0
    roc_auc_preserved  : bool  = True
    # Raw arrays — not stored in summary dict but used for plotting
    _y_true           : Optional[np.ndarray] = field(default=None, repr=False)
    _probs_before     : Optional[np.ndarray] = field(default=None, repr=False)
    _probs_after      : Optional[np.ndarray] = field(default=None, repr=False)

    @classmethod
    def build(
        cls,
        y_true: np.ndarray,
        probs_before: np.ndarray,
        probs_after: np.ndarray,
        dataset_name: str = "",
        calibrator_name: str = "isotonic",
        n_bins: int = DEFAULT_N_BINS,
    ) -> "CalibrationReport":
        """Construct a CalibrationReport from arrays.

        Parameters
        ----------
        y_true : np.ndarray, shape (N,)
            Binary ground-truth labels.
        probs_before : np.ndarray, shape (N,)
            Raw (uncalibrated) fraud probabilities.
        probs_after : np.ndarray, shape (N,)
            Calibrated fraud probabilities.
        dataset_name : str
        calibrator_name : str
        n_bins : int

        Returns
        -------
        CalibrationReport
        """
        from sklearn.metrics import roc_auc_score  # local import to avoid circulars
        auc_before = roc_auc_score(y_true, probs_before)
        auc_after  = roc_auc_score(y_true, probs_after)

        report = cls(
            dataset_name    = dataset_name,
            calibrator_name = calibrator_name,
            n_samples       = int(len(y_true)),
            fraud_rate      = float(y_true.mean() * 100),
            ece_before      = expected_calibration_error(y_true, probs_before, n_bins),
            ece_after       = expected_calibration_error(y_true, probs_after,  n_bins),
            mce_before      = maximum_calibration_error(y_true, probs_before, n_bins),
            mce_after       = maximum_calibration_error(y_true, probs_after,  n_bins),
            brier_before    = float(brier_score_loss(y_true, probs_before)),
            brier_after     = float(brier_score_loss(y_true, probs_after)),
            overconf_before = overconfidence_score(y_true, probs_before, n_bins),
            overconf_after  = overconfidence_score(y_true, probs_after,  n_bins),
            roc_auc_preserved = abs(auc_before - auc_after) < 0.001,
        )
        # Attach arrays for plotting
        report._y_true       = np.asarray(y_true)
        report._probs_before = np.asarray(probs_before)
        report._probs_after  = np.asarray(probs_after)
        return report

    @property
    def ece_improvement(self) -> float:
        """Absolute ECE reduction in percentage points."""
        return self.ece_before - self.ece_after

    @property
    def brier_improvement(self) -> float:
        """Absolute Brier score reduction."""
        return self.brier_before - self.brier_after

    def summary(self) -> str:
        """Multi-line human-readable summary matching Table 2 format."""
        auc_note = "AUC preserved" if self.roc_auc_preserved else "AUC CHANGED"
        return (
            f"CalibrationReport — {self.dataset_name} [{self.calibrator_name}]\n"
            f"  Samples : {self.n_samples:,}  |  Fraud rate: {self.fraud_rate:.3f}%\n"
            f"  ECE     : {self.ece_before:.2f}% → {self.ece_after:.2f}%  "
            f"(Δ = -{self.ece_improvement:.2f}pp)\n"
            f"  MCE     : {self.mce_before:.2f}% → {self.mce_after:.2f}%\n"
            f"  Brier   : {self.brier_before:.4f} → {self.brier_after:.4f}  "
            f"(Δ = -{self.brier_improvement:.4f})\n"
            f"  Overconf: {self.overconf_before:+.2f}% → {self.overconf_after:+.2f}%  "
            f"| {auc_note}"
        )

    def to_dict(self) -> Dict[str, float]:
        """Serialise numeric metrics to a flat dictionary."""
        return {
            "dataset"         : self.dataset_name,
            "calibrator"      : self.calibrator_name,
            "n_samples"       : self.n_samples,
            "fraud_rate_pct"  : round(self.fraud_rate, 4),
            "ece_before_pct"  : round(self.ece_before, 4),
            "ece_after_pct"   : round(self.ece_after,  4),
            "ece_delta_pp"    : round(self.ece_improvement, 4),
            "mce_before_pct"  : round(self.mce_before, 4),
            "mce_after_pct"   : round(self.mce_after,  4),
            "brier_before"    : round(self.brier_before, 6),
            "brier_after"     : round(self.brier_after,  6),
            "brier_delta"     : round(self.brier_improvement, 6),
            "overconf_before" : round(self.overconf_before, 4),
            "overconf_after"  : round(self.overconf_after,  4),
            "roc_auc_preserved": int(self.roc_auc_preserved),
        }

    # ── Plotting ──────────────────────────────────────────────────────────────

    def plot(
        self,
        save_path: Optional[str | Path] = None,
        show: bool = True,
        n_bins: int = DEFAULT_N_BINS,
    ) -> plt.Figure:
        """Plot a four-panel calibration analysis figure (Figure 3 style).

        Panels
        ------
        1. Reliability diagram — before calibration
        2. Reliability diagram — after calibration
        3. Score histogram overlay (fraud vs. legitimate, before/after)
        4. ECE and Brier score comparison bar chart

        Parameters
        ----------
        save_path : str or Path, optional
            If provided, save the figure to this path.
        show : bool, default True
        n_bins : int, default 10

        Returns
        -------
        plt.Figure
        """
        if self._y_true is None:
            raise RuntimeError(
                "No raw arrays attached to this report.  Use CalibrationReport.build()."
            )

        y, pb, pa = self._y_true, self._probs_before, self._probs_after

        fig = plt.figure(figsize=(14, 10))
        fig.suptitle(
            f"Calibration Analysis — {self.dataset_name}  [{self.calibrator_name}]\n"
            f"ECE: {self.ece_before:.2f}% → {self.ece_after:.2f}%  |  "
            f"Brier: {self.brier_before:.4f} → {self.brier_after:.4f}",
            fontsize=12, fontweight="bold",
        )
        gs = gridspec.GridSpec(2, 2, figure=fig, hspace=0.38, wspace=0.32)

        # ── Panel 1: Reliability diagram (before) ─────────────────────────────
        ax1 = fig.add_subplot(gs[0, 0])
        self._draw_reliability_diagram(
            ax1, y, pb, n_bins,
            title=f"Reliability Diagram — Before\n(ECE={self.ece_before:.2f}%)",
            colour="#E63946",
        )

        # ── Panel 2: Reliability diagram (after) ──────────────────────────────
        ax2 = fig.add_subplot(gs[0, 1])
        self._draw_reliability_diagram(
            ax2, y, pa, n_bins,
            title=f"Reliability Diagram — After\n(ECE={self.ece_after:.2f}%)",
            colour="#2DC653",
        )

        # ── Panel 3: Score distribution overlay ───────────────────────────────
        ax3 = fig.add_subplot(gs[1, 0])
        for probs, label, ls in [(pb, "Before cal.", "--"), (pa, "After cal.", "-")]:
            for cls, colour, name in [(0, "#2E86AB", "Legit"), (1, "#E63946", "Fraud")]:
                mask = y == cls
                ax3.hist(
                    probs[mask], bins=50, alpha=0.4 if cls == 0 else 0.7,
                    density=True, color=colour, linestyle=ls,
                    label=f"{name} ({label})", histtype="stepfilled" if cls == 1 else "step",
                )
        ax3.set_xlabel("Predicted fraud probability")
        ax3.set_ylabel("Density")
        ax3.set_title("Score Distribution — Fraud vs. Legitimate")
        ax3.legend(fontsize=7, ncol=2)
        ax3.set_xlim(0, 1)

        # ── Panel 4: Metric comparison bar chart ──────────────────────────────
        ax4 = fig.add_subplot(gs[1, 1])
        metrics = {
            "ECE (%)": (self.ece_before, self.ece_after),
            "MCE (%)": (self.mce_before, self.mce_after),
            "Brier×10": (self.brier_before * 10, self.brier_after * 10),
        }
        x     = np.arange(len(metrics))
        width = 0.35
        labels, before_vals, after_vals = zip(*[
            (k, v[0], v[1]) for k, v in metrics.items()
        ])
        ax4.bar(x - width / 2, before_vals, width, label="Before",
                color="#E63946", alpha=0.85, edgecolor="#333", linewidth=0.5)
        ax4.bar(x + width / 2, after_vals,  width, label="After",
                color="#2DC653", alpha=0.85, edgecolor="#333", linewidth=0.5)

        # Annotate bars
        for bars, vals in [
            (ax4.containers[0], before_vals),
            (ax4.containers[1], after_vals),
        ]:
            for bar, v in zip(bars, vals):
                ax4.text(
                    bar.get_x() + bar.get_width() / 2,
                    bar.get_height() + max(before_vals) * 0.02,
                    f"{v:.3f}", ha="center", fontsize=8,
                )

        ax4.set_xticks(x)
        ax4.set_xticklabels(labels)
        ax4.set_ylabel("Metric value")
        ax4.set_title("Calibration Metrics Before vs. After")
        ax4.legend()

        plt.tight_layout(rect=[0, 0, 1, 0.93])

        if save_path:
            Path(save_path).parent.mkdir(parents=True, exist_ok=True)
            fig.savefig(save_path, bbox_inches="tight")
            logger.info("Calibration figure saved to %s", save_path)
        if show:
            plt.show()
        return fig

    @staticmethod
    def _draw_reliability_diagram(
        ax: plt.Axes,
        y_true: np.ndarray,
        y_prob: np.ndarray,
        n_bins: int,
        title: str,
        colour: str,
    ) -> None:
        """Draw a single reliability diagram panel."""
        frac_pos, mean_pred, bin_counts = reliability_curve(y_true, y_prob, n_bins)

        # Perfect calibration reference line
        ax.plot([0, 1], [0, 1], "k--", linewidth=0.9, alpha=0.5,
                label="Perfect calibration")

        # Calibration curve
        ax.plot(mean_pred, frac_pos, "o-", color=colour, linewidth=1.8,
                markersize=5, label="Model")

        # Shaded gap between curve and diagonal
        for mp, fp in zip(mean_pred, frac_pos):
            ax.plot([mp, mp], [mp, fp], color=colour, alpha=0.25, linewidth=2.5)

        # Histogram of score counts at the bottom
        ax_twin = ax.twinx()
        bin_edges = np.linspace(0, 1, n_bins + 1)
        bin_mids  = (bin_edges[:-1] + bin_edges[1:]) / 2
        # Align histogram with calibration curve points
        n_pts = min(len(bin_mids), len(bin_counts))
        ax_twin.bar(
            bin_mids[:n_pts], bin_counts[:n_pts],
            width=0.9 / n_bins, alpha=0.15, color=colour, label="Count",
        )
        ax_twin.set_ylabel("Sample count", fontsize=8, color="#888")
        ax_twin.tick_params(axis="y", labelsize=7, colors="#888")

        ax.set_xlim(0, 1)
        ax.set_ylim(0, 1)
        ax.set_xlabel("Mean predicted probability")
        ax.set_ylabel("Fraction of positives (fraud rate)")
        ax.set_title(title, fontsize=10, fontweight="bold")
        ax.legend(fontsize=8)



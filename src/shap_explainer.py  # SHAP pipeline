@dataclass
class GlobalImportance:
    """Result of a global SHAP analysis over a validation set.

    Attributes
    ----------
    feature_names : List[str]
        Names of all features in the model's input space (embedding dims).
    mean_abs_shap : np.ndarray, shape (n_features,)
        Mean absolute SHAP value per feature across all explained samples.
        Primary ranking criterion used in the paper's global plots.
    shap_values : np.ndarray, shape (n_samples, n_features)
        Full SHAP value matrix; each row is one transaction's attribution
        vector phi_i(x).
    base_value : float
        Model baseline phi_0: the mean prediction over the background set.
    ranked_features : List[str]
        Feature names sorted by mean_abs_shap descending.
    ranked_importances : np.ndarray
        mean_abs_shap values in the same descending order.
    n_samples : int
        Number of transactions explained.
    """

    feature_names      : List[str]
    mean_abs_shap      : np.ndarray
    shap_values        : np.ndarray
    base_value         : float
    ranked_features    : List[str]
    ranked_importances : np.ndarray
    n_samples          : int

    def top_k(self, k: int = DEFAULT_TOP_K) -> pd.DataFrame:
        """Return a DataFrame of the top-k most important features.

        Parameters
        ----------
        k : int
            Number of top features to return.

        Returns
        -------
        pd.DataFrame
            Columns: feature, mean_abs_shap.  Sorted descending.
        """
        k = min(k, len(self.ranked_features))
        return pd.DataFrame({
            "feature"       : self.ranked_features[:k],
            "mean_abs_shap" : self.ranked_importances[:k],
        })

    def rank_vector(self) -> np.ndarray:
        """Return integer ranks (1 = most important) for all features.

        Used by FraudSHAPExplainer.cross_fold_stability() to compute
        Spearman rank correlations across folds.

        Returns
        -------
        np.ndarray, shape (n_features,)
            Rank of each feature by mean absolute SHAP (1-based).
        """
        order = np.argsort(self.mean_abs_shap)[::-1]
        ranks = np.empty_like(order)
        ranks[order] = np.arange(1, len(order) + 1)
        return ranks


@dataclass
class LocalExplanation:
    """SHAP explanation for a single transaction.

    Corresponds to the "local, per-transaction explanation" described in
    the paper's System Model section (Explainability / SHAP layer).

    Attributes
    ----------
    transaction_id : str
        Caller-supplied identifier (e.g. TransactionID from IEEE-CIS).
    feature_names : List[str]
        Names of all embedding dimensions.
    shap_values : np.ndarray, shape (n_features,)
        Per-feature Shapley contributions phi_i(x).
    base_value : float
        Model baseline phi_0.
    predicted_value : float
        Raw model output F(x) = phi_0 + sum_i phi_i(x).  Local accuracy
        axiom guarantees this equals the classifier's actual output.
    fraud_score : float
        Calibrated fraud probability from the ensemble head.
    decision : int
        Binary fraud decision (0 or 1) at the cost-optimal threshold.
    top_positive : List[Tuple[str, float]]
        Top features that pushed the score towards fraud (phi_i > 0),
        sorted descending.
    top_negative : List[Tuple[str, float]]
        Top features that pushed the score away from fraud (phi_i < 0),
        sorted ascending (most negative first).
    """

    transaction_id  : str
    feature_names   : List[str]
    shap_values     : np.ndarray
    base_value      : float
    predicted_value : float
    fraud_score     : float
    decision        : int
    top_positive    : List[Tuple[str, float]] = field(default_factory=list)
    top_negative    : List[Tuple[str, float]] = field(default_factory=list)

    def to_dict(self) -> Dict[str, Any]:
        """Serialise to a JSON-compatible dictionary.

        Returns a flat audit record suitable for logging to a database,
        API response, or analyst dashboard — matching the paper's
        description of the governance layer that stores "features, score,
        threshold, explanation, version pins, and provenance of data".

        Returns
        -------
        Dict[str, Any]
        """
        return {
            "transaction_id" : self.transaction_id,
            "fraud_score"    : round(float(self.fraud_score), 6),
            "decision"       : int(self.decision),
            "base_value"     : round(float(self.base_value), 6),
            "predicted_value": round(float(self.predicted_value), 6),
            "shap_values"    : {
                name: round(float(val), 6)
                for name, val in zip(self.feature_names, self.shap_values)
            },
            "top_positive_drivers": [
                {"feature": f, "shap": round(v, 6)} for f, v in self.top_positive
            ],
            "top_negative_drivers": [
                {"feature": f, "shap": round(v, 6)} for f, v in self.top_negative
            ],
        }

    def reason_codes(self, top_n: int = 5) -> List[str]:
        """Generate human-readable reason codes for analyst dashboards.

        Returns plain-English strings naming the top features that drove
        the fraud flag, matching the paper's stated goal of giving analysts
        "a reason behind a single flagged transaction".

        Parameters
        ----------
        top_n : int
            Number of reason codes to return.

        Returns
        -------
        List[str]
            E.g. ['z_04 strongly increased fraud probability (+0.312)',
                  'z_11 moderately increased fraud probability (+0.187)', ...]
        """
        codes = []
        for feat, val in self.top_positive[:top_n]:
            magnitude = abs(val)
            if magnitude > 0.3:
                strength = "strongly"
            elif magnitude > 0.1:
                strength = "moderately"
            else:
                strength = "slightly"
            codes.append(f"{feat} {strength} increased fraud probability ({val:+.3f})")
        return codes


@dataclass
class StabilityReport:
    """Cross-fold SHAP stability report.

    Paper: "rank correlation coefficients in the range of 0.8 to 0.9
    indicate that it is not an illusion of the sampling but an overall
    description of what the model is all about in its logic."

    Attributes
    ----------
    n_folds : int
        Number of cross-validation folds compared.
    corr_matrix : np.ndarray, shape (n_folds, n_folds)
        Pairwise Spearman rank correlation matrix.
    mean_corr : float
        Mean off-diagonal Spearman r.
    std_corr : float
        Standard deviation of off-diagonal Spearman r.
    is_stable : bool
        True if mean_corr >= stability_threshold (default 0.75).
    """

    n_folds          : int
    corr_matrix      : np.ndarray
    mean_corr        : float
    std_corr         : float
    is_stable        : bool

    def summary(self) -> str:
        return (
            f"SHAP stability across {self.n_folds} folds: "
            f"mean Spearman r = {self.mean_corr:.3f} ± {self.std_corr:.3f}  "
            f"({'STABLE' if self.is_stable else 'UNSTABLE'})"
        )



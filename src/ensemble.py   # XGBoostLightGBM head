# ═══════════════════════════════════════════════════════════════════════════════
# Evaluation helpers
# ═══════════════════════════════════════════════════════════════════════════════


def evaluate_predictions(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    threshold: float = 0.5,
    cost_fn: float = DEFAULT_COST_FN,
    cost_fp: float = DEFAULT_COST_FP,
) -> Dict[str, float]:
    """Compute the full set of evaluation metrics reported in the paper.

    Covers Table 1 (accuracy, precision, recall, F1, ROC-AUC, PR-AUC),
    Table 2 (Brier score), and the cost-per-100k metric discussed in the
    Results Discussion section.

    Parameters
    ----------
    y_true : np.ndarray, shape (N,)
        Ground-truth binary labels (0 = legitimate, 1 = fraud).
    y_prob : np.ndarray, shape (N,)
        Predicted fraud probabilities in [0, 1].
    threshold : float, default 0.5
        Decision threshold applied to convert probabilities to labels.
        Use cost_optimal_threshold() for the paper's tau*.
    cost_fn : float
        Cost of a missed fraud (false negative).
    cost_fp : float
        Cost of a false alarm (false positive).

    Returns
    -------
    Dict[str, float]
        Keys: accuracy, precision, recall, f1, roc_auc, pr_auc,
        brier, cost_per_100k, tp, tn, fp, fn.
    """
    y_pred = (y_prob >= threshold).astype(int)
    tn, fp, fn, tp = confusion_matrix(y_true, y_pred, labels=[0, 1]).ravel()
    cost = (fn * cost_fn + fp * cost_fp) / len(y_true) * 100_000

    return {
        "accuracy"      : accuracy_score(y_true, y_pred),
        "precision"     : precision_score(y_true, y_pred, zero_division=0),
        "recall"        : recall_score(y_true, y_pred, zero_division=0),
        "f1"            : f1_score(y_true, y_pred, zero_division=0),
        "roc_auc"       : roc_auc_score(y_true, y_prob),
        "pr_auc"        : average_precision_score(y_true, y_prob),
        "brier"         : brier_score_loss(y_true, y_prob),
        "cost_per_100k" : cost,
        "tp": int(tp), "tn": int(tn), "fp": int(fp), "fn": int(fn),
    }


def cost_optimal_threshold(
    cost_fn: float = DEFAULT_COST_FN,
    cost_fp: float = DEFAULT_COST_FP,
) -> float:
    """Compute the Bayes-optimal decision threshold tau* from asymmetric costs.

    From Lemma 1 in the paper (System Model section):

        tau* = c_FP / (c_FP + c_FN)

    The optimal policy is to predict fraud when P_hat(y=1|z) >= tau*.
    This minimises expected cost R(delta) over all measurable rules.

    Parameters
    ----------
    cost_fn : float
        Cost of missing a fraud (false negative).  Paper uses 100.
    cost_fp : float
        Cost of a false alarm (false positive).  Paper uses 1.

    Returns
    -------
    float
        Cost-optimal threshold tau* in (0, 1).

    Examples
    --------
    >>> cost_optimal_threshold(cost_fn=100.0, cost_fp=1.0)
    0.0099...   # very low -> maximises recall
    """
    return cost_fp / (cost_fp + cost_fn)


def expected_calibration_error(
    y_true: np.ndarray,
    y_prob: np.ndarray,
    n_bins: int = 10,
) -> float:
    """Expected Calibration Error (ECE) as a percentage.

    Paper Table 2 reports ECE before/after isotonic calibration:
    Credit Card: 6.1% -> 2.0%, IEEE-CIS: 7.5% -> 2.5%, PaySim: 5.8% -> 1.9%.

        ECE = sum_b (|B_b| / N) * |acc_b - conf_b|

    Parameters
    ----------
    y_true : np.ndarray
        Binary ground-truth labels.
    y_prob : np.ndarray
        Predicted probabilities.
    n_bins : int, default 10
        Number of equal-width probability bins.

    Returns
    -------
    float
        ECE as a percentage.
    """
    bin_edges = np.linspace(0.0, 1.0, n_bins + 1)
    ece = 0.0
    n   = len(y_true)
    for lo, hi in zip(bin_edges[:-1], bin_edges[1:]):
        mask = (y_prob >= lo) & (y_prob < hi)
        if mask.sum() == 0:
            continue
        acc  = y_true[mask].mean()
        conf = y_prob[mask].mean()
        ece += (mask.sum() / n) * abs(acc - conf)
    return ece * 100.0



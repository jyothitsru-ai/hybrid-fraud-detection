   "source": [
    "# Bar chart — reproduces Figure 2 from paper\n",
    "metric_means = {name: {k: np.mean([m[k] for m in folds])\n",
    "                       for k in folds[0]}\n",
    "                for name, folds in all_results.items()}\n",
    "\n",
    "model_names = list(metric_means.keys())\n",
    "colors = ['#ADB5BD', '#6C757D', '#495057', '#343A40', '#E63946']\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
    "for ax, metric, title in [\n",
    "    (axes[0], 'roc_auc', 'ROC-AUC'),\n",
    "    (axes[1], 'pr_auc',  'PR-AUC'),\n",
    "    (axes[2], 'recall',  'Recall'),\n",
    "]:\n",
    "    vals = [metric_means[n][metric] for n in model_names]\n",
    "    bars = ax.bar(range(len(model_names)), vals,\n",
    "                  color=colors, edgecolor='#333', linewidth=0.6)\n",
    "    ax.set_xticks(range(len(model_names)))\n",
    "    ax.set_xticklabels([n.replace(' ', '\\n') for n in model_names], fontsize=8)\n",
    "    ax.set_title(title, fontweight='bold')\n",
    "    ax.set_ylim(min(vals) - 0.05, 1.0)\n",

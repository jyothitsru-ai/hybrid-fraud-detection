    "rows = []\n",
    "for model_name, fold_metrics in all_results.items():\n",
    "    means = {k: np.mean([m[k] for m in fold_metrics]) for k in fold_metrics[0]}\n",
    "    stds  = {k: np.std( [m[k] for m in fold_metrics]) for k in fold_metrics[0]}\n",
    "    rows.append({\n",
    "        'Model'    : model_name,\n",
    "        'Accuracy' : f\"{means['accuracy']*100:.1f} ± {stds['accuracy']*100:.1f}%\",\n",
    "        'Precision': f\"{means['precision']*100:.1f} ± {stds['precision']*100:.1f}%\",\n",
    "        'Recall'   : f\"{means['recall']*100:.1f} ± {stds['recall']*100:.1f}%\",\n",
    "        'F1-score' : f\"{means['f1']*100:.1f} ± {stds['f1']*100:.1f}%\",\n",
    "        'ROC-AUC'  : f\"{means['roc_auc']:.3f} ± {stds['roc_auc']:.3f}\",\n",
    "        'PR-AUC'   : f\"{means['pr_auc']:.3f} ± {stds['pr_auc']:.3f}\",\n",
    "    })\n",
    "\n",
    "results_df = pd.DataFrame(rows).set_index('Model')\n",
    "print('Table 1 — Comparative Performance (mean ± std, 5-fold)\\n')\n",
    "display(results_df)\n",
    "\n",
    "results_df.to_csv(MODELS_DIR / 'results_table1.csv')\n",
    "print('\\nSaved to results/models/results_table1.csv')"
   ]

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Stage 1 — DNN Encoder\n",
    "Architecture: fully connected layers with ReLU, BatchNorm, Dropout. The **penultimate hidden layer** produces the embedding vector `z` passed to Stage 2."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FraudDNNEncoder(nn.Module):\n",
    "    \"\"\"\n",
    "    Deep Neural Network encoder (Stage 1).\n",
    "    Paper: '3 to 5 fully connected hidden layers, ReLU activations,\n",
    "    dropout regularizations to deter overfitting.'\n",
    "\n",
    "    The penultimate layer output is the embedding z passed to the ensemble.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, input_dim: int, hidden_dims: list = [256, 128, 64],\n",
    "                 embedding_dim: int = 32, dropout: float = 0.3):\n",
    "        super().__init__()\n",
    "\n",
    "        layers = []\n",
    "        prev_dim = input_dim\n",
    "        for h_dim in hidden_dims:\n",
    "            layers += [\n",
    "                nn.Linear(prev_dim, h_dim),\n",
    "                nn.BatchNorm1d(h_dim),\n",
    "                nn.ReLU(),\n",
    "                nn.Dropout(p=dropout),\n",
    "            ]\n",
    "            prev_dim = h_dim\n",
    "\n",
    "        self.encoder = nn.Sequential(*layers)\n",
    "\n",
    "        # Embedding (penultimate) layer\n",
    "        self.embedding_layer = nn.Sequential(\n",
    "            nn.Linear(prev_dim, embedding_dim),\n",
    "            nn.BatchNorm1d(embedding_dim),\n",
    "            nn.ReLU(),\n",
    "        )\n",
    "\n",
    "        # Classification head (used during DNN training only)\n",
    "        self.classifier = nn.Linear(embedding_dim, 1)\n",
    "\n",
    "    def forward(self, x, return_embedding: bool = False):\n",
    "        h = self.encoder(x)\n",
    "        z = self.embedding_layer(h)   # embedding vector\n",
    "        if return_embedding:\n",
    "            return z\n",
    "        return self.classifier(z)\n",
    "\n",
    "\n",
    "# ── Test model ────────────────────────────────────────────────────────────────\n",
    "model = FraudDNNEncoder(input_dim=N_FEATURES, embedding_dim=32)\n",
    "dummy = torch.randn(4, N_FEATURES)\n",
    "print(f'Output shape      : {model(dummy).shape}         (logit)')\n",
    "print(f'Embedding shape   : {model(dummy, return_embedding=True).shape}  (z)')\n",
    "\n",
    "total_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "print(f'Trainable params  : {total_params:,}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FocalLoss(nn.Module):\n",
    "    \"\"\"\n",
    "    Focal loss for class-imbalanced training.\n",
    "    Paper: 'cost-sensitive focal loss such that gradients would be stronger\n",
    "    on minority frauds at the decision boundary.'\n",
    "\n",
    "    L_focal = -alpha * y * (1 - p)^gamma * log(p)\n",
    "              -(1 - alpha) * (1 - y) * p^gamma * log(1-p)\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, alpha: float = 0.25, gamma: float = 2.0):\n",
    "        super().__init__()\n",
    "        self.alpha = alpha\n",
    "        self.gamma = gamma\n",
    "\n",
    "    def forward(self, logits, targets):\n",
    "        probs = torch.sigmoid(logits.squeeze())\n",
    "        targets = targets.float()\n",
    "        pt      = probs * targets + (1 - probs) * (1 - targets)\n",
    "        alpha_t = self.alpha * targets + (1 - self.alpha) * (1 - targets)\n",
    "        loss    = -alpha_t * ((1 - pt) ** self.gamma) * torch.log(pt + 1e-8)\n",
    "        return loss.mean()\n",
    "\n",
    "\n",
    "def train_dnn(X_train, y_train, X_val, y_val,\n",
    "              input_dim, embedding_dim=32,\n",
    "              epochs=50, batch_size=1024, lr=1e-3,\n",
    "              patience=7, device=DEVICE):\n",
    "    \"\"\"\n",
    "    Train DNN encoder with focal loss and early stopping.\n",
    "    Returns: trained model, training history.\n",
    "    \"\"\"\n",
    "    model = FraudDNNEncoder(input_dim=input_dim, embedding_dim=embedding_dim).to(device)\n",
    "    criterion = FocalLoss(alpha=0.25, gamma=2.0)\n",
    "    optimizer = optim.Adam(model.parameters(), lr=lr, weight_decay=1e-4)\n",
    "    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, patience=3, factor=0.5)\n",
    "\n",
    "    X_tr_t = torch.FloatTensor(X_train).to(device)\n",
    "    y_tr_t = torch.FloatTensor(y_train).to(device)\n",
    "    X_vl_t = torch.FloatTensor(X_val).to(device)\n",
    "    y_vl_t = torch.FloatTensor(y_val).to(device)\n",
    "\n",
    "    loader = DataLoader(TensorDataset(X_tr_t, y_tr_t),\n",
    "                        batch_size=batch_size, shuffle=True)\n",
    "\n",
    "    history = {'train_loss': [], 'val_auc': []}\n",
    "    best_val_auc, patience_counter, best_state = 0, 0, None\n",
    "\n",
    "    for epoch in range(epochs):\n",
    "        model.train()\n",
    "        epoch_loss = 0\n",
    "        for Xb, yb in loader:\n",
    "            optimizer.zero_grad()\n",
    "            loss = criterion(model(Xb), yb)\n",
    "            loss.backward()\n",
    "            optimizer.step()\n",
    "            epoch_loss += loss.item()\n",
    "\n",
    "        # Validation\n",
    "        model.eval()\n",
    "        with torch.no_grad():\n",
    "            val_probs = torch.sigmoid(model(X_vl_t)).cpu().numpy().flatten()\n",
    "        val_auc = roc_auc_score(y_val, val_probs)\n",
    "        scheduler.step(-val_auc)\n",
    "\n",
    "        avg_loss = epoch_loss / len(loader)\n",
    "        history['train_loss'].append(avg_loss)\n",
    "        history['val_auc'].append(val_auc)\n",
    "\n",
    "        if val_auc > best_val_auc:\n",
    "            best_val_auc   = val_auc\n",
    "            best_state     = {k: v.cpu().clone() for k, v in model.state_dict().items()}\n",
    "            patience_counter = 0\n",
    "        else:\n",
    "            patience_counter += 1\n",
    "            if patience_counter >= patience:\n",
    "                print(f'  Early stop at epoch {epoch+1}. Best val AUC: {best_val_auc:.4f}')\n",
    "                break\n",
    "\n",
    "        if (epoch + 1) % 10 == 0:\n",
    "            print(f'  Epoch {epoch+1:3d} | loss={avg_loss:.4f} | val_AUC={val_auc:.4f}')\n",
    "\n",
    "    model.load_state_dict(best_state)\n",
    "    return model, history\n",
    "\n",
    "\n",
    "print('DNN training functions defined.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Stage 2 — Ensemble Classifier with Bayesian Optimisation\n",
    "XGBoost trained on DNN embeddings. Bayesian search over depth, n_estimators, learning_rate."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def extract_embeddings(model, X, device=DEVICE, batch_size=4096):\n",
    "    \"\"\"Extract embedding vectors z from trained DNN.\"\"\"\n",
    "    model.eval()\n",
    "    embeddings = []\n",
    "    X_t = torch.FloatTensor(X).to(device)\n",
    "    with torch.no_grad():\n",
    "        for i in range(0, len(X), batch_size):\n",
    "            batch = X_t[i:i+batch_size]\n",
    "            z = model(batch, return_embedding=True)\n",
    "            embeddings.append(z.cpu().numpy())\n",
    "    return np.vstack(embeddings)\n",
    "\n",
    "\n",
    "def bayesian_search_xgboost(Z_train, y_train, Z_val, y_val, n_trials=30):\n",
    "    \"\"\"\n",
    "    Bayesian hyperparameter optimisation for XGBoost ensemble head.\n",
    "    Paper: 'depth of the tree, number of estimators and the learning rate\n",
    "    were optimized (Bayesian optimization) to trade off predictive accuracy\n",
    "    and inference speed.'\n",
    "    \"\"\"\n",
    "    # Class weight for imbalance\n",
    "    scale_pos_weight = (y_train == 0).sum() / (y_train == 1).sum()\n",
    "\n",
    "    def objective(trial):\n",
    "        params = {\n",
    "            'n_estimators'     : trial.suggest_int('n_estimators', 100, 600),\n",
    "            'max_depth'        : trial.suggest_int('max_depth', 3, 9),\n",
    "            'learning_rate'    : trial.suggest_float('learning_rate', 0.01, 0.3, log=True),\n",
    "            'subsample'        : trial.suggest_float('subsample', 0.6, 1.0),\n",
    "            'colsample_bytree' : trial.suggest_float('colsample_bytree', 0.6, 1.0),\n",
    "            'reg_alpha'        : trial.suggest_float('reg_alpha', 1e-5, 1.0, log=True),\n",
    "            'reg_lambda'       : trial.suggest_float('reg_lambda', 1e-5, 1.0, log=True),\n",
    "            'scale_pos_weight' : scale_pos_weight,\n",
    "            'use_label_encoder': False,\n",
    "            'eval_metric'      : 'aucpr',\n",
    "            'random_state'     : SEED,\n",
    "            'n_jobs'           : -1,\n",
    "        }\n",
    "        clf = xgb.XGBClassifier(**params)\n",
    "        clf.fit(Z_train, y_train,\n",
    "                eval_set=[(Z_val, y_val)],\n",
    "                early_stopping_rounds=20,\n",
    "                verbose=False)\n",
    "        preds = clf.predict_proba(Z_val)[:, 1]\n",
    "        return average_precision_score(y_val, preds)   # optimise PR-AUC\n",
    "\n",
    "    study = optuna.create_study(direction='maximize',\n",
    "                                 sampler=optuna.samplers.TPESampler(seed=SEED))\n",
    "    study.optimize(objective, n_trials=n_trials, show_progress_bar=False)\n",
    "\n",
    "    best_params = study.best_params\n",
    "    best_params.update({'scale_pos_weight': scale_pos_weight,\n",
    "                        'use_label_encoder': False,\n",
    "                        'eval_metric': 'aucpr',\n",
    "                        'random_state': SEED, 'n_jobs': -1})\n",
    "\n",
    "    print(f'  Best PR-AUC: {study.best_value:.4f}')\n",
    "    print(f'  Best params: {study.best_params}')\n",
    "    return best_params, study\n",
    "\n",
    "\n",
    "print('Ensemble functions defined.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Full 5-Fold Training Loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate(y_true, y_prob, threshold=0.5):\n",
    "    y_pred = (y_prob >= threshold).astype(int)\n",
    "    return {\n",
    "        'accuracy' : accuracy_score(y_true, y_pred),\n",
    "        'precision': precision_score(y_true, y_pred, zero_division=0),\n",
    "        'recall'   : recall_score(y_true, y_pred, zero_division=0),\n",
    "        'f1'       : f1_score(y_true, y_pred, zero_division=0),\n",
    "        'roc_auc'  : roc_auc_score(y_true, y_prob),\n",
    "        'pr_auc'   : average_precision_score(y_true, y_prob),\n",
    "    }\n",
    "\n",
    "\n",
    "# ── Baseline models ───────────────────────────────────────────────────────────\n",
    "BASELINES = {\n",
    "    'Logistic Regression': LogisticRegression(class_weight='balanced', max_iter=1000, random_state=SEED),\n",
    "    'Random Forest'      : RandomForestClassifier(n_estimators=200, class_weight='balanced',\n",
    "                                                   random_state=SEED, n_jobs=-1),\n",
    "    'XGBoost (standalone)': xgb.XGBClassifier(n_estimators=300, max_depth=6,\n",
    "                                               use_label_encoder=False, eval_metric='aucpr',\n",
    "                                               random_state=SEED, n_jobs=-1),\n",
    "}\n",
    "\n",
    "all_results = {name: [] for name in list(BASELINES.keys()) + ['Standalone DNN', 'Hybrid DNN+XGBoost']}\n",
    "fold_histories = []\n",
    "\n",
    "print('Starting 5-fold training...\\n')\n",
    "\n",
    "for fold_idx, fold in enumerate(fold_data):\n",
    "    print(f'━━━ Fold {fold_idx + 1}/{N_FOLDS} ━━━')\n",
    "    X_train, y_train = fold['X_train'], fold['y_train']\n",
    "    X_val,   y_val   = fold['X_val'],   fold['y_val']\n",
    "\n",
    "    # ── Baselines ─────────────────────────────────────────────────────────────\n",
    "    for name, clf in BASELINES.items():\n",
    "        clf.fit(X_train, y_train)\n",
    "        prob = clf.predict_proba(X_val)[:, 1]\n",
    "        metrics = evaluate(y_val, prob)\n",
    "        all_results[name].append(metrics)\n",
    "        print(f'  {name:25s} ROC-AUC={metrics[\"roc_auc\"]:.4f}  PR-AUC={metrics[\"pr_auc\"]:.4f}')\n",
    "\n",
    "    # ── Stage 1: Train DNN ────────────────────────────────────────────────────\n",
    "    print(f'  Training DNN encoder...')\n",
    "    dnn_model, history = train_dnn(X_train, y_train, X_val, y_val,\n",
    "                                    input_dim=N_FEATURES, embedding_dim=32,\n",
    "                                    epochs=50, patience=7)\n",
    "    fold_histories.append(history)\n",
    "\n",
    "    # Standalone DNN evaluation\n",
    "    dnn_model.eval()\n",
    "    with torch.no_grad():\n",
    "        dnn_probs = torch.sigmoid(\n",
    "            dnn_model(torch.FloatTensor(X_val).to(DEVICE))\n",
    "        ).cpu().numpy().flatten()\n",
    "    dnn_metrics = evaluate(y_val, dnn_probs)\n",
    "    all_results['Standalone DNN'].append(dnn_metrics)\n",
    "    print(f'  {\"Standalone DNN\":25s} ROC-AUC={dnn_metrics[\"roc_auc\"]:.4f}  PR-AUC={dnn_metrics[\"pr_auc\"]:.4f}')\n",
    "\n",
    "    # ── Stage 2: Hybrid — ensemble on embeddings ──────────────────────────────\n",
    "    Z_train = extract_embeddings(dnn_model, X_train)\n",
    "    Z_val   = extract_embeddings(dnn_model, X_val)\n",
    "\n",
    "    print(f'  Bayesian search for XGBoost (30 trials)...')\n",
    "    best_params, _ = bayesian_search_xgboost(Z_train, y_train, Z_val, y_val, n_trials=30)\n",
    "\n",
    "    xgb_clf = xgb.XGBClassifier(**best_params)\n",
    "    xgb_clf.fit(Z_train, y_train,\n",
    "                eval_set=[(Z_val, y_val)],\n",
    "                early_stopping_rounds=20, verbose=False)\n",
    "\n",
    "    hybrid_probs = xgb_clf.predict_proba(Z_val)[:, 1]\n",
    "    hybrid_metrics = evaluate(y_val, hybrid_probs)\n",
    "    all_results['Hybrid DNN+XGBoost'].append(hybrid_metrics)\n",
    "    print(f'  {\"Hybrid DNN+XGBoost\":25s} ROC-AUC={hybrid_metrics[\"roc_auc\"]:.4f}  PR-AUC={hybrid_metrics[\"pr_auc\"]:.4f}')\n",
    "\n",
    "    # Save fold models\n",
    "    torch.save(dnn_model.state_dict(), MODELS_DIR / f'dnn_fold{fold_idx}.pt')\n",
    "    xgb_clf.save_model(str(MODELS_DIR / f'xgb_fold{fold_idx}.json'))\n",
    "    print()"
   ]
  },
  {
